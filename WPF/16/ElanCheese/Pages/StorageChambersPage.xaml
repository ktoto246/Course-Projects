<Page x:Class="ElanCheeseApp.Pages.StorageChambersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      d:DesignHeight="680" d:DesignWidth="1000"
      Title="Камеры хранения"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True"
      TextOptions.TextFormattingMode="Display"
      Background="{StaticResource BackgroundColor}">
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Камеры хранения" Style="{StaticResource HeaderTextStyle}"/>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>
            
            <!-- DataGrid -->
            <Border Style="{StaticResource CardStyle}">
                <DataGrid x:Name="ChambersDataGrid" 
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="OnChambersSelectionChanged"
                          Margin="0,0,8,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="Номер" Binding="{Binding ChamberNumber}" Width="80"/>
                        <DataGridTextColumn Header="Температура" Binding="{Binding Temperature}" Width="100"/>
                        <DataGridTextColumn Header="Влажность" Binding="{Binding Humidity}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
            
            <!-- Панель управления -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Управление" Style="{StaticResource HeaderTextStyle}"/>
                    
                    <Label Content="Номер камеры:" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="ChamberNumberTextBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12"/>
                    
                    <Label Content="Температура:" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TemperatureTextBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12"/>
                    
                    <Label Content="Влажность:" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="HumidityTextBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="Добавить" Style="{StaticResource ButtonStyle}" Click="OnAddClick"/>
                        <Button Content="Сохранить" Style="{StaticResource ButtonStyle}" Click="OnSaveClick"/>
                        <Button Content="Удалить" Style="{StaticResource DangerButtonStyle}" Click="OnDeleteClick"/>
                        <Button Content="Очистить" Style="{StaticResource ClearButtonStyle}" Click="OnClearClick"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>

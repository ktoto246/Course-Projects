<Page x:Class="ElanCheeseApp.Pages.CheeseBatchesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      d:DesignHeight="680" d:DesignWidth="1000"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True"
      TextOptions.TextFormattingMode="Display"
      Title="Партии сыра"
      Background="{StaticResource BackgroundColor}">
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Партии сыра" Style="{StaticResource HeaderTextStyle}"/>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>
            
            <!-- DataGrid -->
            <Border Style="{StaticResource CardStyle}">
                <DataGrid x:Name="BatchesDataGrid" 
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="OnBatchesSelectionChanged"
                          Margin="0,0,8,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="Сорт сыра" Binding="{Binding Variety.Name}" Width="*"/>
                        <DataGridTextColumn Header="Камера" Binding="{Binding Chamber.ChamberNumber}" Width="80"/>
                        <DataGridTextColumn Header="Сотрудник" Binding="{Binding Employee.FullName}" Width="*"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding ProductionDate, StringFormat='dd.MM.yyyy'}" Width="100"/>
                        <DataGridTextColumn Header="Вес (кг)" Binding="{Binding WeightKg}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
            
            <!-- Панель управления -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Управление" Style="{StaticResource HeaderTextStyle}"/>
                    
                    <Label Content="Сорт сыра:" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="VarietyComboBox" Margin="0,0,0,12"/>
                    
                    <Label Content="Камера хранения:" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="ChamberComboBox" Margin="0,0,0,12"/>
                    
                    <Label Content="Сотрудник:" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="EmployeeComboBox" Margin="0,0,0,12"/>
                    
                    <Label Content="Дата производства:" Style="{StaticResource LabelStyle}"/>
                    <DatePicker x:Name="ProductionDatePicker" Margin="0,0,0,12"/>
                    
                    <Label Content="Вес (кг):" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="WeightTextBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="Добавить" Style="{StaticResource ButtonStyle}" Click="OnAddClick"/>
                        <Button Content="Сохранить" Style="{StaticResource ButtonStyle}" Click="OnSaveClick"/>
                        <Button Content="Удалить" Style="{StaticResource DangerButtonStyle}" Click="OnDeleteClick"/>
                        <Button Content="Очистить" Style="{StaticResource ClearButtonStyle}" Click="OnClearClick"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>

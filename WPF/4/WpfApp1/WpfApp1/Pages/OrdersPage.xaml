<Page x:Class="WpfApp1.Pages.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Заказы" Loaded="Page_Loaded">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Поиск (ID чека):" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="TxtSearch" Width="150" TextChanged="TxtSearch_TextChanged"/>
            </StackPanel>

            <DataGrid x:Name="GridOrders" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                      SelectionMode="Single" SelectionChanged="GridOrders_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№ Чека" Binding="{Binding Id}" Width="80"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding OrderDate, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="130"/>
                    <DataGridTextColumn Header="Сотрудник" Binding="{Binding Employee.FullName}" Width="*"/>
                    <DataGridTextColumn Header="Клиент" Binding="{Binding Customer.FullName}" Width="*"/>
                    <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Column="1" Background="#EAEAEA" Padding="15" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Редактор чека (шапка)" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                <TextBlock Text="Сотрудник:"/>
                <ComboBox x:Name="CmbEmployee" DisplayMemberPath="FullName" SelectedValuePath="Id" Margin="0,0,0,10"/>

                <TextBlock Text="Клиент (необязательно):"/>
                <ComboBox x:Name="CmbCustomer" DisplayMemberPath="FullName" SelectedValuePath="Id" Margin="0,0,0,10"/>

                <TextBlock Text="Сумма чека:"/>
                <TextBox x:Name="TxtTotalAmount" Margin="0,0,0,20"/>

                <Button x:Name="BtnAdd" Content="Добавить" Height="35" Margin="0,0,0,5" Click="BtnAdd_Click" Background="#4CAF50" Foreground="White"/>
                <Button x:Name="BtnEdit" Content="Изменить" Height="35" Margin="0,0,0,5" Click="BtnEdit_Click" Background="#FF9800" Foreground="White"/>
                <Button x:Name="BtnDelete" Content="Удалить" Height="35" Margin="0,0,0,5" Click="BtnDelete_Click" Background="#F44336" Foreground="White"/>
                <Button x:Name="BtnClear" Content="Очистить" Height="35" Click="BtnClear_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
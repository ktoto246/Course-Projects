<Page x:Class="WpfApp1.Pages.EmployeesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Сотрудники" Loaded="Page_Loaded">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Поиск (Имя):" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="TxtSearch" Width="200" TextChanged="TxtSearch_TextChanged"/>
            </StackPanel>

            <DataGrid x:Name="GridEmployees" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                      SelectionMode="Single" SelectionChanged="GridEmployees_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Column="1" Background="#EAEAEA" Padding="15" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Управление сотрудником" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                <TextBlock Text="ФИО:"/>
                <TextBox x:Name="TxtFullName" Margin="0,0,0,10"/>

                <TextBlock Text="Должность:"/>
                <TextBox x:Name="TxtPosition" Margin="0,0,0,20"/>

                <Button x:Name="BtnAdd" Content="Добавить" Height="35" Margin="0,0,0,5" Click="BtnAdd_Click" Background="#4CAF50" Foreground="White"/>
                <Button x:Name="BtnEdit" Content="Изменить" Height="35" Margin="0,0,0,5" Click="BtnEdit_Click" Background="#FF9800" Foreground="White"/>
                <Button x:Name="BtnDelete" Content="Удалить" Height="35" Margin="0,0,0,5" Click="BtnDelete_Click" Background="#F44336" Foreground="White"/>
                <Button x:Name="BtnClear" Content="Очистить" Height="35" Click="BtnClear_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
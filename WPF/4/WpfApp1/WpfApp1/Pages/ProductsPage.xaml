<Page x:Class="WpfApp1.Pages.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Товары" Loaded="Page_Loaded">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="TxtSearch" Width="200" Margin="0,0,15,0" TextChanged="TxtSearch_TextChanged"/>

                <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="CmbFilterCategory" Width="150" DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="CmbFilterCategory_SelectionChanged"/>
                <Button x:Name="BtnResetFilter" Content="Сбросить" Width="70" Margin="5,0,0,0" Click="BtnResetFilter_Click"/>
            </StackPanel>

            <DataGrid x:Name="GridProducts" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                      SelectionMode="Single" SelectionChanged="GridProducts_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Категория" Binding="{Binding Category.Name}" Width="120"/>
                    <DataGridTextColumn Header="Артикул" Binding="{Binding SKU}" Width="100"/>
                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="80"/>
                    <DataGridTextColumn Header="Остаток" Binding="{Binding StockQuantity}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Column="1" Background="#EAEAEA" Padding="15" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Управление товаром" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                <TextBlock Text="Категория:"/>
                <ComboBox x:Name="CmbFormCategory" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,10"/>

                <TextBlock Text="Артикул (SKU):"/>
                <TextBox x:Name="TxtSKU" Margin="0,0,0,10"/>

                <TextBlock Text="Название:"/>
                <TextBox x:Name="TxtName" Margin="0,0,0,10"/>

                <TextBlock Text="Цена:"/>
                <TextBox x:Name="TxtPrice" Margin="0,0,0,10"/>

                <TextBlock Text="Остаток на складе:"/>
                <TextBox x:Name="TxtStock" Margin="0,0,0,20"/>

                <Button x:Name="BtnAdd" Content="Добавить" Height="35" Margin="0,0,0,5" Click="BtnAdd_Click" Background="#4CAF50" Foreground="White"/>
                <Button x:Name="BtnEdit" Content="Изменить" Height="35" Margin="0,0,0,5" Click="BtnEdit_Click" Background="#FF9800" Foreground="White"/>
                <Button x:Name="BtnDelete" Content="Удалить" Height="35" Margin="0,0,0,5" Click="BtnDelete_Click" Background="#F44336" Foreground="White"/>
                <Button x:Name="BtnClear" Content="Очистить форму" Height="35" Click="BtnClear_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
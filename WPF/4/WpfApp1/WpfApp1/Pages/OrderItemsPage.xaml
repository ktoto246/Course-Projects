<Page x:Class="WpfApp1.Pages.OrderItemsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Состав заказа" Loaded="Page_Loaded">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Фильтр по ID чека:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="TxtSearchOrder" Width="100" TextChanged="TxtSearchOrder_TextChanged"/>
            </StackPanel>

            <DataGrid x:Name="GridOrderItems" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                      SelectionMode="Single" SelectionChanged="GridOrderItems_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID Позиции" Binding="{Binding Id}" Width="80"/>
                    <DataGridTextColumn Header="№ Чека" Binding="{Binding OrderId}" Width="80"/>
                    <DataGridTextColumn Header="Товар" Binding="{Binding Product.Name}" Width="*"/>
                    <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
                    <DataGridTextColumn Header="Цена за шт." Binding="{Binding UnitPrice}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Column="1" Background="#EAEAEA" Padding="15" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Позиция в чеке" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                <TextBlock Text="Чек (Заказ):"/>
                <ComboBox x:Name="CmbOrder" DisplayMemberPath="Id" SelectedValuePath="Id" Margin="0,0,0,10"/>

                <TextBlock Text="Товар:"/>
                <ComboBox x:Name="CmbProduct" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,10" SelectionChanged="CmbProduct_SelectionChanged"/>

                <TextBlock Text="Количество:"/>
                <TextBox x:Name="TxtQuantity" Margin="0,0,0,10"/>

                <TextBlock Text="Цена за штуку (на момент продажи):"/>
                <TextBox x:Name="TxtUnitPrice" Margin="0,0,0,20"/>

                <Button x:Name="BtnAdd" Content="Добавить" Height="35" Margin="0,0,0,5" Click="BtnAdd_Click" Background="#4CAF50" Foreground="White"/>
                <Button x:Name="BtnEdit" Content="Изменить" Height="35" Margin="0,0,0,5" Click="BtnEdit_Click" Background="#FF9800" Foreground="White"/>
                <Button x:Name="BtnDelete" Content="Удалить" Height="35" Margin="0,0,0,5" Click="BtnDelete_Click" Background="#F44336" Foreground="White"/>
                <Button x:Name="BtnClear" Content="Очистить" Height="35" Click="BtnClear_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
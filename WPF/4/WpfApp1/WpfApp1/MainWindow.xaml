<Window x:Class="WpfApp1.MainWindow"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Retail Admin Panel" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2D2D30">
            <StackPanel Margin="10,20,10,10">
                <TextBlock Text="МЕНЮ" Foreground="White" FontSize="20" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <Button x:Name="BtnProducts" Content="Товары" Height="45" Margin="0,0,0,10" 
        Background="#3E3E42" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand"/>

                <Button x:Name="BtnCategories" Content="Категории" Height="45" Margin="0,0,0,10" 
        Background="#3E3E42" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand"/>

                <Button x:Name="BtnCustomers" Content="Клиенты" Height="45" Margin="0,0,0,10" 
        Background="#3E3E42" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand"/>

                <Button x:Name="BtnOrders" Content="Заказы" Height="45" Margin="0,0,0,10" 
        Background="#3E3E42" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand"/>

                <Button x:Name="BtnEmployees" Content="Сотрудники" Height="45" Margin="0,0,0,10" 
        Background="#3E3E42" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand"/>

                <Button x:Name="BtnOrderItems" Content="Состав заказа" Height="45" Margin="0,0,0,10" 
        Background="#3E3E42" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand"/>

                <Button x:Name="BtnAnalytics" Content="Аналитика" Height="45" Margin="0,0,0,10" 
        Background="#3E3E42" Foreground="White" FontSize="16" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
        <Border Grid.Column="1" Background="#F5F5F5">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Border>
    </Grid>
</Window>
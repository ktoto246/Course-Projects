<Page x:Class="WpfApp1.DealsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Сделки" Background="#FFFFFF">

    <Page.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#F9F9F9"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0"/>
            <Setter Property="VerticalGridLinesBrush" Value="#E0E0E0"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
    </Page.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,10">
            <TextBlock Text="Поиск по клиенту/сотруднику:" Foreground="#333333" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="TxtSearch" Width="250" Height="30" TextChanged="TxtSearch_TextChanged" />
        </StackPanel>

        <DataGrid x:Name="DataGridDeals" Grid.Row="1" Grid.Column="0" AutoGenerateColumns="False" 
                  CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single"
                  SelectionChanged="DataGridDeals_SelectionChanged" 
                  HeadersVisibility="Column" Margin="0,0,10,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                <!-- Показываем реальные названия благодаря Include() в коде -->
                <DataGridTextColumn Header="Клиент" Binding="{Binding Client.CompanyName}" Width="*"/>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding Employee.FullName}" Width="*"/>
                <DataGridTextColumn Header="Продукт" Binding="{Binding Product.ProductName}" Width="*"/>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="60"/>
                <DataGridTextColumn Header="Итого" Binding="{Binding TotalAmount}" Width="90"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding DealDate, StringFormat=d}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="15">
            <StackPanel>
                <TextBlock Text="УПРАВЛЕНИЕ СДЕЛКАМИ" Foreground="#333333" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <TextBlock Text="Клиент:" Foreground="#555555" Margin="0,0,0,5"/>
                <ComboBox x:Name="CmbClients" Height="30" Margin="0,0,0,10" 
                          DisplayMemberPath="CompanyName" SelectedValuePath="Id"/>

                <TextBlock Text="Сотрудник:" Foreground="#555555" Margin="0,0,0,5"/>
                <ComboBox x:Name="CmbEmployees" Height="30" Margin="0,0,0,10" 
                          DisplayMemberPath="FullName" SelectedValuePath="Id"/>

                <TextBlock Text="Продукт:" Foreground="#555555" Margin="0,0,0,5"/>
                <ComboBox x:Name="CmbProducts" Height="30" Margin="0,0,0,10" 
                          DisplayMemberPath="ProductName" SelectedValuePath="Id" SelectionChanged="CmbProducts_SelectionChanged"/>

                <TextBlock Text="Количество:" Foreground="#555555" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtQuantity" Height="30" Margin="0,0,0,10" TextChanged="TxtQuantity_TextChanged"/>

                <TextBlock Text="Итоговая сумма (авто):" Foreground="#555555" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtTotalAmount" Height="30" Margin="0,0,0,15" IsReadOnly="True" Background="#EEEEEE"/>

                <Button Content="Добавить" Height="35" Margin="0,0,0,10" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnAdd_Click"/>
                <Button Content="Изменить" Height="35" Margin="0,0,0,10" Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnEdit_Click"/>
                <Button Content="Удалить" Height="35" Margin="0,0,0,10" Background="#DC3545" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnDelete_Click"/>
                <Button Content="Очистить поля" Height="35" Background="#6C757D" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnClear_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
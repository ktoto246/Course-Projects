<Page x:Class="WpfApp1.ClientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Клиенты" Background="#FFFFFF">

    <Page.Resources>
        <!-- Светлый стиль полей ввода -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Светлый стиль таблицы -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#F9F9F9"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0"/>
            <Setter Property="VerticalGridLinesBrush" Value="#E0E0E0"/>
        </Style>

        <!-- Светлый стиль заголовков таблицы -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
    </Page.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Строка для поиска -->
            <RowDefinition Height="*"/>
            <!-- Строка для таблицы -->
        </Grid.RowDefinitions>

        <!-- Строка поиска (Сверху слева) -->
        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,10">
            <TextBlock Text="Поиск:" Foreground="#333333" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="TxtSearch" Width="300" Height="30" TextChanged="TxtSearch_TextChanged" />
            <TextBlock Text="(по названию, контакту или телефону)" Foreground="#999999" VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>

        <!-- Таблица данных -->
        <DataGrid x:Name="DataGridClients" Grid.Row="1" Grid.Column="0" AutoGenerateColumns="False" 
                  CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single"
                  SelectionChanged="DataGridClients_SelectionChanged" 
                  HeadersVisibility="Column" Margin="0,0,10,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название компании" Binding="{Binding CompanyName}" Width="*"/>
                <DataGridTextColumn Header="Контактное лицо" Binding="{Binding ContactPerson}" Width="*"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель управления -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="15">
            <StackPanel>
                <TextBlock Text="УПРАВЛЕНИЕ ЗАПИСЯМИ" Foreground="#333333" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Название компании:" Foreground="#555555" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtCompanyName" Height="30" Margin="0,0,0,10"/>

                <TextBlock Text="Контактное лицо:" Foreground="#555555" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtContactPerson" Height="30" Margin="0,0,0,10"/>

                <TextBlock Text="Телефон:" Foreground="#555555" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtPhone" Height="30" Margin="0,0,0,20"/>

                <Button Content="Добавить" Height="35" Margin="0,0,0,10" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnAdd_Click"/>
                <Button Content="Изменить" Height="35" Margin="0,0,0,10" Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnEdit_Click"/>
                <Button Content="Удалить" Height="35" Margin="0,0,0,10" Background="#DC3545" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnDelete_Click"/>
                <Button Content="Очистить поля" Height="35" Background="#6C757D" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnClear_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
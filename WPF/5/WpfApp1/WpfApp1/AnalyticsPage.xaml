<Page x:Class="WpfApp1.AnalyticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="Аналитика" Background="#FFFFFF">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,20">
            <TextBlock Text="АНАЛИТИКА: ВЫРУЧКА ПО ПРОДУКТАМ" Foreground="#333333" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="10">
            <lvc:CartesianChart Series="{Binding Series}" XAxes="{Binding XAxes}"/>
        </Border>
    </Grid>
</Page>
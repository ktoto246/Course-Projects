<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Учет отгрузки муки - Балашовский комбинат" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#FFF8DC">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B4513"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E6CA98"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D4B47A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F5DEB3" BorderBrush="#DEB887" BorderThickness="0,0,2,0">
            <StackPanel Margin="5,15,5,5">
                <TextBlock Text="НАВИГАЦИЯ" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="10,10,10,20" Foreground="#6B340B"/>

                <Button Content="Мельницы" Style="{StaticResource MenuButtonStyle}" Click="OnNavButtonClick"/>
                <Button Content="Продукты" Style="{StaticResource MenuButtonStyle}" Click="OnNavButtonClick"/>
                <Button Content="Клиенты" Style="{StaticResource MenuButtonStyle}" Click="OnNavButtonClick"/>
                <Button Content="Заказы" Style="{StaticResource MenuButtonStyle}" Click="OnNavButtonClick"/>
                <Button Content="Детали заказов" Style="{StaticResource MenuButtonStyle}" Click="OnNavButtonClick"/>

                <Separator Margin="15,20,15,20" Background="#DEB887"/>

                <Button Content="Графики" Style="{StaticResource MenuButtonStyle}" Click="OnNavButtonClick"/>
            </StackPanel>
        </Border>

        <Frame x:Name="MainContentFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Margin="10"/>
    </Grid>
</Window>
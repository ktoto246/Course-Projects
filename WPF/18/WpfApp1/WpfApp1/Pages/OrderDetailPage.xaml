<Page x:Class="WpfApp1.Pages.OrderDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d"
      Background="#FFF8DC"
      Title="Детали заказов">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Поиск (по продукту):" FontSize="14" FontWeight="Bold" Foreground="#8B4513" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="txtSearch" Width="250" TextChanged="OnSearchTextChanged" Padding="5"/>
        </StackPanel>

        <DataGrid x:Name="dataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="OnDataGridSelectionChanged" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding OrderDetailId}" Width="50"/>
                <DataGridTextColumn Header="№ Заказа" Binding="{Binding OrderId}" Width="80"/>
                <DataGridTextColumn Header="Продукт" Binding="{Binding Product.ProductName}" Width="*"/>
                <DataGridTextColumn Header="Количество (т)" Binding="{Binding QuantityTons}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <WrapPanel Grid.Row="2" Margin="0,10">
            <StackPanel Orientation="Horizontal" Margin="0,5,15,5">
                <TextBlock Text="Заказ (ID):" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <ComboBox x:Name="cbOrder" Width="100"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5,15,5">
                <TextBlock Text="Продукт:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <ComboBox x:Name="cbProduct" Width="200"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5,15,5">
                <TextBlock Text="Кол-во (тонн):" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtQuantityTons" Width="100"/>
            </StackPanel>
        </WrapPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Добавить" Width="100" Height="30" Margin="10,0,0,0" Click="OnAddClick" Background="#F5DEB3" Foreground="#8B4513"/>
            <Button Content="Изменить" Width="100" Height="30" Margin="10,0,0,0" Click="OnEditClick" Background="#F5DEB3" Foreground="#8B4513"/>
            <Button Content="Удалить" Width="100" Height="30" Margin="10,0,0,0" Click="OnDeleteClick" Background="#FFDAB9" Foreground="#8B4513"/>
            <Button Content="Очистить" Width="100" Height="30" Margin="10,0,0,0" Click="OnClearClick" Background="#EEE8AA" Foreground="#8B4513"/>
        </StackPanel>
    </Grid>
</Page>
<Page x:Class="WpfApp1.Pages.ClientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d"
      Background="#FFF8DC"
      Title="Клиенты">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Поиск клиента:" FontSize="14" FontWeight="Bold" Foreground="#8B4513" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="txtSearch" Width="250" TextChanged="OnSearchTextChanged" Padding="5"/>
        </StackPanel>

        <DataGrid x:Name="dataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="OnDataGridSelectionChanged" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ClientId}" Width="50"/>
                <DataGridTextColumn Header="Название организации" Binding="{Binding ClientName}" Width="*"/>
                <DataGridTextColumn Header="ИНН" Binding="{Binding Inn}" Width="120"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="150"/>
                <DataGridTextColumn Header="Юр. Адрес" Binding="{Binding LegalAddress}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <WrapPanel Grid.Row="2" Margin="0,10">
            <StackPanel Orientation="Horizontal" Margin="0,5,15,5">
                <TextBlock Text="Название:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtName" Width="180"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5,15,5">
                <TextBlock Text="ИНН:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtInn" Width="120" MaxLength="12"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5,15,5">
                <TextBlock Text="Телефон:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtPhone" Width="150"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5,15,5">
                <TextBlock Text="Адрес:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtAddress" Width="200"/>
            </StackPanel>
        </WrapPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Добавить" Width="100" Height="30" Margin="10,0,0,0" Click="OnAddClick" Background="#F5DEB3" Foreground="#8B4513"/>
            <Button Content="Изменить" Width="100" Height="30" Margin="10,0,0,0" Click="OnEditClick" Background="#F5DEB3" Foreground="#8B4513"/>
            <Button Content="Удалить" Width="100" Height="30" Margin="10,0,0,0" Click="OnDeleteClick" Background="#FFDAB9" Foreground="#8B4513"/>
            <Button Content="Очистить" Width="100" Height="30" Margin="10,0,0,0" Click="OnClearClick" Background="#EEE8AA" Foreground="#8B4513"/>
        </StackPanel>
    </Grid>
</Page>
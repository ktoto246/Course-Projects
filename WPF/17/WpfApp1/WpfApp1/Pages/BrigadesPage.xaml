<Page x:Class="WpfApp1.Pages.BrigadesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="900"
      Title="BrigadesPage">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="txtSearch" Height="35" FontSize="14" VerticalContentAlignment="Center" Padding="10,0" BorderBrush="#CCCCCC" BorderThickness="1"/>
            <Button x:Name="btnSearch" Grid.Column="1" Content="Поиск" Width="100" Height="35" Margin="10,0,0,0" Background="#005A9E" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnSearch_Click"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="dgBrigades" Grid.Column="0" Margin="0,0,10,0" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="DgBrigades_SelectionChanged" BorderBrush="#CCCCCC" BorderThickness="1" RowBackground="White" AlternatingRowBackground="#F9F9F9" CanUserSortColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                    <DataGridTextColumn Header="Район" Binding="{Binding District.Name}" Width="*"/>
                    <DataGridTextColumn Header="Позывной" Binding="{Binding CallSign}" Width="*"/>
                    <DataGridTextColumn Header="Руководитель" Binding="{Binding LeaderName}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <GroupBox Grid.Column="1" Header="Состав бригады" FontWeight="SemiBold" BorderBrush="#CCCCCC">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="dgWorkers" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" BorderThickness="0" Background="White" RowBackground="White" AlternatingRowBackground="#F9F9F9" FontWeight="Normal" Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Vertical" Margin="5">
                        <TextBlock Text="Новый рабочий (ФИО и Должность):" Foreground="#666666" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtWorkerName" Grid.Column="0" Height="30" Margin="0,0,5,0" ToolTip="Например: Иванов И.И."/>
                            <TextBox x:Name="txtWorkerPosition" Grid.Column="1" Height="30" Margin="5,0,0,0" ToolTip="Например: Водитель"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="btnAddWorker" Content="Добавить" Width="90" Height="30" Background="#005A9E" Foreground="White" FontWeight="Bold" Cursor="Hand" Margin="0,0,10,0" Click="BtnAddWorker_Click"/>
                            <Button x:Name="btnDeleteWorker" Content="Уволить" Width="90" Height="30" Background="#DC3545" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnDeleteWorker_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <Border Grid.Row="2" Background="White" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Margin="0,10,0,10" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Район:" VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold"/>
                <ComboBox x:Name="cboDistrict" Grid.Row="0" Grid.Column="1" Height="30" Margin="0,0,0,10" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Позывной:" VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold"/>
                <TextBox x:Name="txtCallSign" Grid.Row="1" Grid.Column="1" Height="30" Margin="0,0,0,10"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Руководитель:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                <TextBox x:Name="txtLeaderName" Grid.Row="2" Grid.Column="1" Height="30" Margin="0,0,0,0"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnSave" Content="Сохранить" Width="120" Height="35" Margin="0,0,10,0" Background="#28A745" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnSave_Click"/>
            <Button x:Name="btnClear" Content="Очистить" Width="120" Height="35" Margin="0,0,10,0" Background="#6C757D" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnClear_Click"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="120" Height="35" Background="#DC3545" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnDelete_Click"/>
        </StackPanel>
    </Grid>
</Page>
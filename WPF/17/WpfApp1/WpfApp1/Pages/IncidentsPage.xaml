<Page x:Class="WpfApp1.Pages.IncidentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="IncidentsPage">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="txtSearch" Height="35" FontSize="14" VerticalContentAlignment="Center" Padding="10,0" BorderBrush="#CCCCCC" BorderThickness="1"/>
            <Button x:Name="btnSearch" Grid.Column="1" Content="Поиск" Width="100" Height="35" Margin="10,0,0,0" Background="#005A9E" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnSearch_Click"/>
        </Grid>

        <DataGrid x:Name="dgIncidents" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="DgIncidents_SelectionChanged" BorderBrush="#CCCCCC" BorderThickness="1" RowBackground="White" AlternatingRowBackground="#F9F9F9" CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Район" Binding="{Binding District.Name}" Width="*"/>
                <DataGridTextColumn Header="Оборудование" Binding="{Binding EquipmentType.Name}" Width="*"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="2*"/>
                <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="White" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Margin="0,10,0,10" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Район:" VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold"/>
                <ComboBox x:Name="cboDistrict" Grid.Row="0" Grid.Column="1" Height="30" Margin="0,0,20,10" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Оборудование:" VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold"/>
                <ComboBox x:Name="cboEquipment" Grid.Row="0" Grid.Column="3" Height="30" Margin="0,0,0,10" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Статус:" VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold"/>
                <ComboBox x:Name="cboStatus" Grid.Row="1" Grid.Column="1" Height="30" Margin="0,0,20,10">
                    <ComboBoxItem Content="В обработке"/>
                    <ComboBoxItem Content="Бригада выехала"/>
                    <ComboBoxItem Content="Устранено"/>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Дата создания:" VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold"/>
                <DatePicker x:Name="dpCreatedAt" Grid.Row="1" Grid.Column="3" Height="30" Margin="0,0,0,10" SelectedDateFormat="Short"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Описание:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                <TextBox x:Name="txtDescription" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,0"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnSave" Content="Сохранить" Width="120" Height="35" Margin="0,0,10,0" Background="#28A745" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnSave_Click"/>
            <Button x:Name="btnClear" Content="Очистить" Width="120" Height="35" Margin="0,0,10,0" Background="#6C757D" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnClear_Click"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="120" Height="35" Background="#DC3545" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnDelete_Click"/>
        </StackPanel>
    </Grid>
</Page>
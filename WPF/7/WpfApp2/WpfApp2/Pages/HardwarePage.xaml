<Page x:Class="WpfApp2.Pages.HardwarePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Оборудование">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <DataGrid x:Name="GridData" Grid.Column="0" AutoGenerateColumns="False" IsReadOnly="True" 
                  Margin="0,0,15,0" SelectionChanged="GridData_SelectionChanged"
                  Background="White" RowHeight="30" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Название}" Width="*"/>
                <DataGridTextColumn Header="Производитель" Binding="{Binding Производитель}" Width="120"/>
                <DataGridTextColumn Header="Серийник" Binding="{Binding СерийныйНомер}" Width="120"/>
                <DataGridTextColumn Header="РМ (Инв.№)" Binding="{Binding РабочееМесто.ИнвентарныйНомер}" Width="120"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding ДатаПриобретения, StringFormat=dd.MM.yyyy}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
            <StackPanel DataContext="{Binding CurrentItem}">
                <TextBlock Text="Название *" FontWeight="Bold" Foreground="#3F4254"/>
                <TextBox Text="{Binding Название, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <TextBlock Text="Производитель" FontWeight="Bold" Foreground="#3F4254"/>
                <TextBox Text="{Binding Производитель, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <TextBlock Text="Серийный номер" FontWeight="Bold" Foreground="#3F4254"/>
                <TextBox Text="{Binding СерийныйНомер, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <TextBlock Text="Дата приобретения" FontWeight="Bold" Foreground="#3F4254"/>
                <DatePicker SelectedDate="{Binding ДатаПриобретения}" Margin="0,0,0,10" Height="30"/>

                <TextBlock Text="Рабочее место *" FontWeight="Bold" Foreground="#3F4254"/>
                <ComboBox x:Name="CmbРабочиеМеста" SelectedValue="{Binding РабочееМестоId}" DisplayMemberPath="ИнвентарныйНомер" SelectedValuePath="Id" Margin="0,0,0,15" Height="30"/>

                <StackPanel Margin="0,10,0,0">
                    <Button Style="{StaticResource ModernBtnStyle}" Background="#1BC5BD" Content="Добавить" Click="AddBtn_Click" Margin="0,0,0,10" Height="40"/>
                    <Button Style="{StaticResource ModernBtnStyle}" Background="#FFA800" Content="Обновить" Click="UpdateBtn_Click" Margin="0,0,0,10" Height="40"/>
                    <Button Style="{StaticResource ModernBtnStyle}" Background="#F64E60" Content="Удалить" Click="DeleteBtn_Click" Margin="0,0,0,10" Height="40"/>
                    <Button Style="{StaticResource ModernBtnStyle}" Background="#E4E6EF" Foreground="#3F4254" Content="Очистить" Click="ClearBtn_Click" Height="40"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
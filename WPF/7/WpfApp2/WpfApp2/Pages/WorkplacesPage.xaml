<Page x:Class="WpfApp2.Pages.WorkplacesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Рабочие места">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <DataGrid x:Name="GridData" Grid.Column="0" AutoGenerateColumns="False" IsReadOnly="True" 
                  Margin="0,0,15,0" SelectionChanged="GridData_SelectionChanged"
                  Background="White" RowHeight="30" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Инв. №" Binding="{Binding ИнвентарныйНомер}" Width="150"/>
                <DataGridTextColumn Header="Расположение" Binding="{Binding Расположение}" Width="*"/>
                <DataGridTextColumn Header="Отдел" Binding="{Binding Отдел.Название}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Column="1" DataContext="{Binding CurrentItem}">
            <TextBlock Text="Инвентарный № *" FontWeight="Bold" Foreground="#3F4254"/>
            <TextBox Text="{Binding ИнвентарныйНомер, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

            <TextBlock Text="Расположение" FontWeight="Bold" Foreground="#3F4254"/>
            <TextBox Text="{Binding Расположение, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

            <TextBlock Text="Отдел *" FontWeight="Bold" Foreground="#3F4254"/>
            <ComboBox x:Name="CmbОтделы" SelectedValue="{Binding ОтделId}" DisplayMemberPath="Название" SelectedValuePath="Id" Margin="0,0,0,15" Height="30"/>

            <StackPanel Margin="0,10,0,0">
                <Button Style="{StaticResource ModernBtnStyle}" Background="#1BC5BD" Content="Добавить" Click="AddBtn_Click" Margin="0,0,0,10" Height="40"/>
                <Button Style="{StaticResource ModernBtnStyle}" Background="#FFA800" Content="Обновить" Click="UpdateBtn_Click" Margin="0,0,0,10" Height="40"/>
                <Button Style="{StaticResource ModernBtnStyle}" Background="#F64E60" Content="Удалить" Click="DeleteBtn_Click" Margin="0,0,0,10" Height="40"/>
                <Button Style="{StaticResource ModernBtnStyle}" Background="#E4E6EF" Foreground="#3F4254" Content="Очистить" Click="ClearBtn_Click" Height="40"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
<Page x:Class="WpfApp2.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="Дашборд">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Аналитика и статистика ИТ-Активов" FontSize="24" FontWeight="Bold" Foreground="#3F4254" Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>


            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Распределение установленного ПО" FontWeight="SemiBold" FontSize="16" Foreground="#3F4254" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <lvc:PieChart Grid.Row="1" Series="{Binding PieSeries}" LegendPosition="Right"/>
                </Grid>
            </Border>


            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="15" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Количество рабочих мест по отделам" FontWeight="SemiBold" FontSize="16" Foreground="#3F4254" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding BarSeries}" XAxes="{Binding XAxes}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
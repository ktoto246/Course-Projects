<UserControl x:Class="WpfApp1.Pages.EmployeesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="EmployeesDataGrid" Grid.Row="0" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single" Margin="0,0,0,15"
                  SelectionChanged="EmployeesDataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding EmployeeID}" Width="50"/>
                <DataGridTextColumn Header="ФИО сотрудника" Binding="{Binding FullName}" Width="250"/>
                <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="ФИО:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <TextBox x:Name="NameTextBox" Grid.Column="1" Padding="8,5" Margin="0,5,10,5"/>

            <TextBlock Grid.Column="2" Text="Должность:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <TextBox x:Name="PosTextBox" Grid.Column="3" Padding="8,5" Margin="0,5,0,5"/>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Добавить" Width="100" Padding="5" Click="AddBtn_Click" Background="#27AE60" Foreground="White" BorderThickness="0" Margin="0,0,10,0"/>
            <Button Content="Изменить" Width="100" Padding="5" Click="UpdateBtn_Click" Background="#2980B9" Foreground="White" BorderThickness="0" Margin="0,0,10,0"/>
            <Button Content="Удалить" Width="100" Padding="5" Click="DeleteBtn_Click" Background="#C0392B" Foreground="White" BorderThickness="0"/>
            <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" Margin="15,0,0,0" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</UserControl>
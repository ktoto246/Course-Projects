<UserControl x:Class="WpfApp1.Pages.EquipmentPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8F9FA" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchTextBox" Grid.Column="0" Padding="8,5" Margin="0,0,10,0" 
                         TextChanged="SearchTextBox_TextChanged" ToolTip="Поиск по инв. номеру, названию, модели"/>

                <Button Grid.Column="2" Content="Сбросить" Width="100" Height="30" Margin="0,0,10,0" 
                        Click="ResetSearchBtn_Click" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>

                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <ComboBox x:Name="FilterStatusCombo" Width="150" Padding="8,5" Margin="0,0,5,0" 
          SelectionChanged="FilterStatusCombo_SelectionChanged" 
          ToolTip="Фильтр по статусу"/>

                    <ComboBox x:Name="FilterUnitCombo" Width="150" Padding="8,5" 
          SelectionChanged="FilterUnitCombo_SelectionChanged" 
          ToolTip="Фильтр по цеху"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid x:Name="EquipmentDataGrid" Grid.Row="1" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single" Margin="0,0,0,15"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionChanged="EquipmentDataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Инв. номер" Binding="{Binding InventoryNumber}" Width="100"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding EquipmentName}" Width="*"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type.TypeName}" Width="120"/>
                <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer.ManufacturerName}" Width="120"/>
                <DataGridTextColumn Header="Цех" Binding="{Binding Unit.UnitName}" Width="120"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status.StatusName}" Width="100"/>
                <DataGridTextColumn Header="След. ТО" Binding="{Binding NextMaintenanceDate}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Инв. номер:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <TextBox x:Name="InvNumTextBox" Grid.Row="0" Grid.Column="1" Padding="8,5" Margin="0,5,10,5"/>
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Наименование:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <TextBox x:Name="NameTextBox" Grid.Row="0" Grid.Column="3" Padding="8,5" Margin="0,5,0,5"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Тип:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <ComboBox x:Name="TypeComboBox" Grid.Row="1" Grid.Column="1" Padding="8,5" Margin="0,5,10,5"/>
            <TextBlock Grid.Row="1" Grid.Column="2" Text="Производитель:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <ComboBox x:Name="ManufacturerComboBox" Grid.Row="1" Grid.Column="3" Padding="8,5" Margin="0,5,0,5"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Модель:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <TextBox x:Name="ModelTextBox" Grid.Row="2" Grid.Column="1" Padding="8,5" Margin="0,5,10,5"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="Цех:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <ComboBox x:Name="UnitComboBox" Grid.Row="2" Grid.Column="3" Padding="8,5" Margin="0,5,0,5"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Статус:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <ComboBox x:Name="StatusComboBox" Grid.Row="3" Grid.Column="1" Padding="8,5" Margin="0,5,10,5"/>
            <TextBlock Grid.Row="3" Grid.Column="2" Text="Дата установки:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <DatePicker x:Name="InstallDatePicker" Grid.Row="3" Grid.Column="3" Padding="8,5" Margin="0,5,0,5"/>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
            <Button Content="Добавить" Width="120" Height="35" Margin="0,0,10,0" Click="AddBtn_Click" Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Изменить" Width="120" Height="35" Margin="0,0,10,0" Click="UpdateBtn_Click" Background="#2980B9" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Удалить" Width="120" Height="35" Click="DeleteBtn_Click" Background="#C0392B" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Очистить" Width="100" Height="35" Margin="10,0,0,0" Click="ClearBtn_Click" Background="#7F8C8D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>

        <TextBlock x:Name="StatusTextBlock" Grid.Row="4" Foreground="Red" FontSize="13" FontWeight="SemiBold"/>
    </Grid>
</UserControl>
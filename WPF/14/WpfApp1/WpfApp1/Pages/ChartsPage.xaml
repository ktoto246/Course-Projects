<UserControl x:Class="WpfApp1.Pages.ChartsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="White"
             Loaded="UserControl_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>
            <TextBlock Text="Затраты на техническое обслуживание" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" Foreground="#2C3E50"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Период с:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14" Foreground="#34495E"/>
                <DatePicker x:Name="StartDatePicker" Width="120" Margin="0,0,20,0"/>
                <TextBlock Text="по:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14" Foreground="#34495E"/>
                <DatePicker x:Name="EndDatePicker" Width="120" Margin="0,0,20,0"/>
                <Button Content="Применить" Width="100" Padding="5" Click="ApplyFilter_Click" Background="#3498DB" Foreground="White" BorderThickness="0"/>
            </StackPanel>

            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="Затраты на ТО по месяцам (₽)" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="#34495E"/>
                    
                    <lvc:CartesianChart x:Name="CostLineChart" Height="400"/>
                </StackPanel>
            </Border>

            <TextBlock x:Name="StatusTextBlock" Foreground="Red" FontSize="13" FontWeight="SemiBold" Margin="0,10,0,0" TextAlignment="Center"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
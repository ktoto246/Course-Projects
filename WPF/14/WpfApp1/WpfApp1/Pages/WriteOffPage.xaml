<UserControl x:Class="WpfApp1.Pages.WriteOffPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8F9FA" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchTextBox" Grid.Column="0" Padding="8,5" Margin="0,0,10,0" 
                         TextChanged="SearchTextBox_TextChanged" ToolTip="Поиск по инв. номеру, названию, модели"/>
                <Button Grid.Column="1" Content="⟲ Сбросить" Width="100" Height="30" 
                        Click="ResetSearchBtn_Click" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <DataGrid x:Name="WriteOffDataGrid" Grid.Row="1" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single" Margin="0,0,0,15"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionChanged="WriteOffDataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Инв. номер" Binding="{Binding InventoryNumber}" Width="110"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding EquipmentName}" Width="*"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status.StatusName}" Width="100"/>
                <DataGridTextColumn Header="Дата списания" Binding="{Binding WriteOffDate}" Width="110"/>
                <DataGridTextColumn Header="Стоимость ремонта" Binding="{Binding WriteOffRepairCost, StringFormat={}{0:N2} ₽}" Width="130"/>
                <DataGridTextColumn Header="Стоимость деталей" Binding="{Binding WriteOffPartsCost, StringFormat={}{0:N2} ₽}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Оборудование:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <ComboBox x:Name="EquipmentComboBox" Grid.Row="0" Grid.Column="1" Padding="8,5" Margin="0,5,10,5"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="Дата списания:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <DatePicker x:Name="WriteOffDatePicker" Grid.Row="0" Grid.Column="3" Padding="8,5" Margin="0,5,0,5"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Стоимость ремонта:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <TextBox x:Name="RepairCostTextBox" Grid.Row="1" Grid.Column="1" Padding="8,5" Margin="0,5,10,5" PreviewTextInput="NumberPreviewTextInput"/>

            <TextBlock Grid.Row="1" Grid.Column="2" Text="Стоимость деталей:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <TextBox x:Name="PartsCostTextBox" Grid.Row="1" Grid.Column="3" Padding="8,5" Margin="0,5,0,5" PreviewTextInput="NumberPreviewTextInput"/>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
            <Button Content="Оформить списание" Width="150" Height="35" Margin="0,0,10,0" Click="SaveBtn_Click" Background="#C0392B" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Очистить" Width="100" Height="35" Click="ClearBtn_Click" Background="#7F8C8D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>

        <TextBlock x:Name="StatusTextBlock" Grid.Row="4" Foreground="Red" FontSize="13" FontWeight="SemiBold"/>
    </Grid>
</UserControl>
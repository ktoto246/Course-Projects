<UserControl x:Class="WpfApp1.Pages.MaintenancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8F9FA" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchTextBox" Grid.Column="0" Padding="8,5" Margin="0,0,10,0" 
                         TextChanged="SearchTextBox_TextChanged" ToolTip="Поиск по инв. номеру, сотруднику или описанию"/>


                <Button Grid.Column="2" Content="Сбросить" Width="100" Height="30" Margin="0,0,10,0"
                        Click="ResetSearchBtn_Click" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>

                <ComboBox x:Name="FilterTypeCombo" Grid.Column="3" Width="160" Padding="8,5"
                          SelectionChanged="FilterTypeCombo_SelectionChanged" ToolTip="Фильтр по типу работ"/>
            </Grid>
        </Border>

        <DataGrid x:Name="MaintenanceDataGrid" Grid.Row="1" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single" Margin="0,0,0,15"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionChanged="MaintenanceDataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding RecordID}" Width="50"/>
                <DataGridTextColumn Header="Оборудование" Binding="{Binding Equipment.InventoryNumber}" Width="110"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding MaintenanceDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Тип работ" Binding="{Binding MaintenanceType}" Width="130"/>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding Employee.FullName}" Width="120"/>
                <DataGridTextColumn Header="Стоимость" Binding="{Binding Cost, StringFormat={}{0:N2} ₽}" Width="100"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Оборудование:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <ComboBox x:Name="EquipmentComboBox" Grid.Row="0" Grid.Column="1" Padding="8,5" Margin="0,5,10,5"/>
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Дата работ:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <DatePicker x:Name="DateDatePicker" Grid.Row="0" Grid.Column="3" Padding="8,5" Margin="0,5,0,5"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Тип работ:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <ComboBox x:Name="TypeComboBox" Grid.Row="1" Grid.Column="1" Padding="8,5" Margin="0,5,10,5">
                <ComboBoxItem Content="Плановое ТО"/>
                <ComboBoxItem Content="Внеплановый ремонт"/>
                <ComboBoxItem Content="Диагностика"/>
            </ComboBox>
            <TextBlock Grid.Row="1" Grid.Column="2" Text="Стоимость:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <TextBox x:Name="CostTextBox" Grid.Row="1" Grid.Column="3" Padding="8,5" Margin="0,5,0,5" PreviewTextInput="NumberPreviewTextInput"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Сотрудник:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <ComboBox x:Name="TechComboBox" Grid.Row="2" Grid.Column="1" Padding="8,5" Margin="0,5,10,5"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="Описание:" VerticalAlignment="Center" Margin="0,5,10,5"/>
            <TextBox x:Name="DescTextBox" Grid.Row="2" Grid.Column="3" Padding="8,5" Margin="0,5,0,5"/>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
            <Button Content="Добавить" Width="120" Height="35" Margin="0,0,10,0" Click="AddBtn_Click" Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Изменить" Width="120" Height="35" Margin="0,0,10,0" Click="UpdateBtn_Click" Background="#2980B9" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Удалить" Width="120" Height="35" Click="DeleteBtn_Click" Background="#C0392B" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Очистить" Width="100" Height="35" Margin="10,0,0,0" Click="ClearBtn_Click" Background="#7F8C8D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>

        <TextBlock x:Name="StatusTextBlock" Grid.Row="4" Foreground="Red" FontSize="13" FontWeight="SemiBold"/>
    </Grid>
</UserControl>
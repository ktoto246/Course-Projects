<UserControl x:Class="WpfApp1.Pages.ManufacturersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8F9FA" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchTextBox" Grid.Column="0" Padding="8,5" Margin="0,0,10,0" 
                         TextChanged="SearchTextBox_TextChanged" ToolTip="Поиск по названию или стране"/>

                <Button Grid.Column="2" Content="Сбросить" Width="100" Height="30" 
                        Click="ResetSearchBtn_Click" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <DataGrid x:Name="ManufacturersDataGrid" Grid.Row="1" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single" Margin="0,0,0,15"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionChanged="ManufacturersDataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ManufacturerID}" Width="60"/>
                <DataGridTextColumn Header="Производитель" Binding="{Binding ManufacturerName}" Width="*"/>
                <DataGridTextColumn Header="Страна" Binding="{Binding Country}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Производитель:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
            <TextBox x:Name="NameTextBox" Grid.Column="1" Padding="8,5" FontSize="14"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Страна:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
            <TextBox x:Name="CountryTextBox" Grid.Column="1" Padding="8,5" FontSize="14"/>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
            <Button Content="Добавить" Width="120" Height="35" Margin="0,0,10,0" Click="AddBtn_Click" Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Изменить" Width="120" Height="35" Margin="0,0,10,0" Click="UpdateBtn_Click" Background="#2980B9" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Удалить" Width="120" Height="35" Click="DeleteBtn_Click" Background="#C0392B" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Очистить" Width="100" Height="35" Margin="10,0,0,0" Click="ClearBtn_Click" Background="#7F8C8D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>

        <TextBlock x:Name="StatusTextBlock" Grid.Row="5" Foreground="Red" FontSize="13" FontWeight="SemiBold"/>
    </Grid>
</UserControl>
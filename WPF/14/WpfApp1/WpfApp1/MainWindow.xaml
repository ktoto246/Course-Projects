<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
         Title="БАЛТЕКС - Учет оборудования" Height="700" Width="1200" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Margin="10,20,10,10">
                <TextBlock Text="БАЛТЕКС" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                <Button Content="Цеха" Margin="0,5" Padding="10,8" Click="NavBtn_Click" Tag="ProductionUnitsPage" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Производители" Margin="0,5" Padding="10,8" Click="NavBtn_Click" Tag="ManufacturersPage" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Типы оборудования" Margin="0,5" Padding="10,8" Click="NavBtn_Click" Tag="EquipmentTypesPage" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Статусы" Margin="0,5" Padding="10,8" Click="NavBtn_Click" Tag="EquipmentStatusesPage" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Сотрудники" Margin="0,5" Padding="10,8" Click="NavBtn_Click" Tag="EmployeesPage" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Оборудование" Margin="0,5" Padding="10,8" Click="NavBtn_Click" Tag="EquipmentPage" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Журнал ТО" Margin="0,5" Padding="10,8" Click="NavBtn_Click" Tag="MaintenancePage" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Списание оборудования" Margin="0,5" Padding="10,8" Click="NavBtn_Click" Tag="WriteOffPage" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Графики" Margin="0,5" Padding="10,8" Click="NavBtn_Click" Tag="ChartsPage" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
        <Border Grid.Column="1" Background="White" Margin="10" BorderBrush="#CCCCCC" BorderThickness="1">
            <ContentControl x:Name="MainContent"/>
        </Border>
    </Grid>
</Window>

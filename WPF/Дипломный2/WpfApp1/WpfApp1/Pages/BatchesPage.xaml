<Page x:Class="WpfApp1.Pages.BatchesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Партии зерна" Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <StackPanel Margin="0,0,20,0">
                <TextBlock Text="Поиск (по номеру авто)" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,5"/>
                <TextBox x:Name="txtSearch" Width="250" Height="35" VerticalContentAlignment="Center" Padding="10,0" TextChanged="txtSearch_TextChanged"/>
            </StackPanel>
            <Button Content="Экспорт в Excel" Width="130" Height="35" Background="#107C41" Foreground="White" FontWeight="Bold" Margin="0,15,10,0" Click="btnExportToExcel_Click"/>
            <Button x:Name="btnSaveChanges" Content="Сохранить изменения" Width="160" Height="35" Background="#3498DB" Foreground="White" FontWeight="Bold" Margin="0,15,10,0" Click="btnSaveChanges_Click"/>
            <Button x:Name="btnDeleteBatch" Content="Удалить" Width="100" Height="35" Background="#EF4444" Foreground="White" FontWeight="Bold" Margin="0,15,0,0" Click="btnDeleteBatch_Click"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
            <WrapPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,15,10">
                    <TextBlock Text="Клиент" FontSize="11" Foreground="#64748B" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbClient" Width="180" Height="35" VerticalContentAlignment="Center" DisplayMemberPath="CompanyName"/>
                </StackPanel>
                <StackPanel Margin="0,0,15,10">
                    <TextBlock Text="Культура" FontSize="11" Foreground="#64748B" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbCrop" Width="130" Height="35" VerticalContentAlignment="Center" DisplayMemberPath="Name"/>
                </StackPanel>
                <StackPanel Margin="0,0,15,10">
                    <TextBlock Text="Склад" FontSize="11" Foreground="#64748B" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbStorage" Width="130" Height="35" VerticalContentAlignment="Center" DisplayMemberPath="Name"/>
                </StackPanel>
                <StackPanel Margin="0,0,15,10">
                    <TextBlock Text="Авто" FontSize="11" Foreground="#64748B" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtCarNumber" Width="100" Height="35" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>
                <StackPanel Margin="0,0,15,10">
                    <TextBlock Text="Брутто (т)" FontSize="11" Foreground="#64748B" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtGrossWeight" Width="80" Height="35" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>
                <StackPanel Margin="0,0,15,10">
                    <TextBlock Text="Тара (т)" FontSize="11" Foreground="#64748B" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtTareWeight" Width="80" Height="35" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>
                <Button x:Name="btnAddBatch" Content="Добавить" Width="90" Height="35" Background="#E67E22" Foreground="White" FontWeight="Bold" VerticalAlignment="Bottom" Margin="0,0,0,10" Click="btnAddBatch_Click"/>
            </WrapPanel>
        </Border>

        <DataGrid Grid.Row="2" x:Name="dgBatches" AutoGenerateColumns="False" SelectionMode="Single" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" IsReadOnly="True" Visibility="Collapsed"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding Client.CompanyName}" Width="150" IsReadOnly="True"/>
                <DataGridTextColumn Header="Культура" Binding="{Binding Crop.Name}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Склад" Binding="{Binding Storage.Name}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Авто" Binding="{Binding CarNumber}" Width="100"/>
                <DataGridTextColumn Header="Брутто" Binding="{Binding GrossWeight}" Width="80"/>
                <DataGridTextColumn Header="Тара" Binding="{Binding TareWeight}" Width="80"/>
                <DataGridTextColumn Header="Нетто" Binding="{Binding NetWeight}" Width="80" IsReadOnly="True"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
<Page x:Class="WpfApp1.Pages.WeigherDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Дашборд Весовщика" Background="#F8FAFC">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="alertBorder" Grid.Row="0" Background="#FEE2E2" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#FCA5A5" BorderThickness="1" Visibility="Collapsed">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="КРИТИЧЕСКИЙ СИГНАЛ: ИСТЁК СРОК ХРАНЕНИЯ ЗЕРНА (>30 ДНЕЙ)" FontWeight="Bold" Foreground="#991B1B" FontSize="14"/>
                </StackPanel>
                <ItemsControl x:Name="icAlerts">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="#7F1D1D" Margin="0,2" FontSize="13" FontWeight="Medium"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Принято сегодня" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtBatchesToday" Text="0 шт." FontSize="32" FontWeight="Bold" Foreground="#1E293B" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Очередь в лабораторию" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtWaitingLab" Text="0 шт." FontSize="32" FontWeight="Bold" Foreground="#F59E0B" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Нетто за смену" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtNetWeightToday" Text="0,0 т" FontSize="32" FontWeight="Bold" Foreground="#10B981" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Background="White" CornerRadius="8" Padding="15" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Пиковый склад" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtMaxLoadedStorage" Text="Нет" FontSize="20" FontWeight="Bold" Foreground="#EF4444" Margin="0,10,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,10,0" BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Текущие статусы партий на сегодня" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>
                    <ItemsControl x:Name="icStatuses" Grid.Row="1">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding StatusName}" FontSize="14" Foreground="#475569" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Background="{Binding BadgeColor}" Padding="10,4" CornerRadius="12">
                                        <TextBlock Text="{Binding Count, StringFormat={}{0} шт.}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Объемы принятых культур за смену" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>
                    <ItemsControl x:Name="icCrops" Grid.Row="1">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding CropName}" FontSize="14" Foreground="#475569" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <ProgressBar Grid.Column="1" Value="{Binding Count}" Maximum="{Binding MaxCount}" Height="12" Foreground="{Binding BarColor}" Background="#F1F5F9" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Инвентарный мониторинг и загруженность складов" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>
                <ItemsControl x:Name="icFreeSpace" Grid.Row="1">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding StorageName}" FontSize="13" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="1" Text="{Binding StoredCrops, StringFormat={}Сырьё: {0}}" FontSize="12" Foreground="#64748B" FontStyle="Italic" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <ProgressBar Grid.Column="2" Value="{Binding CurrentLoad}" Maximum="{Binding Capacity}" Height="14" BorderThickness="0" Background="#F1F5F9" Foreground="{Binding BarColor}" Margin="15,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{Binding SpaceText}" FontSize="13" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</Page>
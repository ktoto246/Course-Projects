<Page x:Class="WpfApp1.Pages.ManagerDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      Title="Дашборд Менеджера" Background="#F8FAFC">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="📊 Фильтр аналитики по датам — С:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                <DatePicker x:Name="dpStart" Width="130" Margin="0,0,15,0"/>
                <TextBlock Text="По:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                <DatePicker x:Name="dpEnd" Width="130" Margin="0,0,20,0"/>
                <Button x:Name="btnApplyFilter" Content="Применить фильтр" Padding="15,6" Background="#3B82F6" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Click="btnApplyFilter_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Выручка за период" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtRevenueToday" Text="0 ₽" FontSize="28" FontWeight="Bold" Foreground="#10B981" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Оказано услуг (выписано)" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtServicesCount" Text="0 ед." FontSize="28" FontWeight="Bold" Foreground="#3B82F6" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Партий без услуг (очередь)" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtPendingBatches" Text="0 шт." FontSize="28" FontWeight="Bold" Foreground="#F59E0B" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Background="White" CornerRadius="8" Padding="15" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Средний чек партии" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtAverageCheck" Text="0 ₽" FontSize="28" FontWeight="Bold" Foreground="#6366F1" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,15,0" BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Доли выручки по категориям услуг" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>
                    <lvc:PieChart x:Name="pieChartRevenue" Grid.Row="1" LegendLocation="Right" InnerRadius="40"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Рейтинг контрагентов по выручке" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>
                    <ItemsControl x:Name="icTopClients" Grid.Row="1">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ClientName}" FontSize="13" Foreground="#475569" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <ProgressBar Grid.Column="1" Value="{Binding Revenue}" Maximum="{Binding MaxRevenue}" Height="8" Foreground="#6366F1" Background="#F1F5F9" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding RevenueText}" FontSize="13" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Динамика поступления средств по дням" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>
                <lvc:CartesianChart x:Name="lineChartRevenue" Grid.Row="1">
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis x:Name="axisXDays" Title="Временная шкала" LabelsRotation="25"/>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="Сумма" MinValue="0" LabelFormatter="{Binding CurrencyFormatter}"/>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </Grid>
        </Border>
    </Grid>
</Page>
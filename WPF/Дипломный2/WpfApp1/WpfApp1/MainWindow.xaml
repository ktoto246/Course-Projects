<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Главное окно" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5" FontFamily="Segoe UI"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D1D5DB"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#374151"/>
                                <Setter Property="Foreground" Value="#E67E22"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#111827"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogoutButton" TargetType="Button" BasedOn="{StaticResource MenuButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#374151"/>
                                <Setter Property="Foreground" Value="#EF4444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#111827"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1F2937">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="60"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ХЛЕБНАЯ БАЗА" FontSize="20" FontWeight="Black" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                    <Button x:Name="btnDashboard" Content="Дашборд" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnEmployees" Content="Сотрудники" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnClients" Content="Клиенты" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnCrops" Content="Справочник культур" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnStorages" Content="Склады" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnServices" Content="Услуги" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnBatches" Content="Партии зерна" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnLabTests" Content="Лабораторные анализы" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnRenderedServices" Content="Оказанные услуги" Style="{StaticResource MenuButton}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="20,0,10,0" VerticalAlignment="Center">
                    <TextBlock x:Name="txtUserName" Text="ФИО" Foreground="#9CA3AF" FontSize="13" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="txtUserRole" Text="Роль" Foreground="#E67E22" FontSize="11" FontWeight="Bold" Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Row="3" x:Name="btnLogout" Content="Выход из профиля" Style="{StaticResource LogoutButton}" Click="btnLogout_Click"/>
            </Grid>
        </Border>

        <Frame Grid.Column="1" x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
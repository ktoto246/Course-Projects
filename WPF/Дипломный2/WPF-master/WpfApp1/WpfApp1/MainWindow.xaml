<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учет технических средств" Height="800" Width="1500" WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgLight}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Grid.Column="0" Background="{StaticResource BgDark}">
            <StackPanel Margin="0,30,0,10">
                <TextBlock Text="АСУ Оборудование" Foreground="White" FontWeight="Bold" FontSize="20" Margin="20,0,0,40"/>
                
                <TextBlock Text="ОСНОВНОЕ" Foreground="#64748B" FontSize="12" FontWeight="Bold" Margin="20,10,0,5"/>
                <Button x:Name="BtnEquipments" Content="Оборудование" Style="{StaticResource NavButton}" Click="BtnEquipments_Click"/>
                <Button x:Name="BtnMovementHistory" Content="Журнал перемещений" Style="{StaticResource NavButton}" Click="BtnMovementHistory_Click"/>
                <Button x:Name="BtnRepairHistory" Content="Журнал ремонтов" Style="{StaticResource NavButton}" Click="BtnRepairHistory_Click"/>

                    <TextBlock x:Name="LblSpravochniki" Text="СПРАВОЧНИКИ" Foreground="#64748B" FontSize="12" FontWeight="Bold" Margin="20,25,0,5"/>
                    <Button x:Name="BtnEmployees" Content="Сотрудники" Style="{StaticResource NavButton}" Click="BtnEmployees_Click"/>
                <Button x:Name="BtnDictionaries" Content="Категории" Style="{StaticResource NavButton}" Click="BtnDictionaries_Click"/>
                <Button x:Name="BtnStatuses" Content="Статусы" Style="{StaticResource NavButton}" Click="BtnStatuses_Click"/>
                    <TextBlock x:Name="LblAnalytics" Text="АНАЛИТИКА" Foreground="#64748B" FontSize="12" FontWeight="Bold" Margin="20,25,0,5"/>
                    <Button x:Name="BtnStatusChart" Content="Статусы" Style="{StaticResource NavButton}" Click="BtnStatusChart_Click"/>
                    <Button x:Name="BtnCategoryChart" Content="Категории" Style="{StaticResource NavButton}" Click="BtnCategoryChart_Click"/>
                    <Button x:Name="BtnFinancial" Content="Стоимость фонда" Click="OpenFinancial_Click" Style="{StaticResource NavButton}"/>
                    <Button x:Name="BtnDeadlines" Content="Контроль сроков" Click="OpenDeadlines_Click" Style="{StaticResource NavButton}"/>
                    <Button x:Name="BtnRepairCosts" Content="Затраты на ремонт" Click="OpenRepairCosts_Click" Style="{StaticResource NavButton}"/>
                    <Button x:Name="BtnWorkload" Content="Нагрузка персонала" Click="OpenWorkload_Click" Style="{StaticResource NavButton}"/>
                    <Button Content="Сменить пользователя" Click="BtnLogout_Click" Style="{StaticResource NavButton}" Margin="0,25,0,5"/>
            </StackPanel>
        </Grid>
        </ScrollViewer>


        <Border Grid.Column="1" Background="{StaticResource BgLight}">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Margin="0"/>
        </Border>
    </Grid>
</Window>


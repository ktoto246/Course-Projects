<Page x:Class="WpfApp1.Pages.StatusAnalyticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="Аналитика по статусам">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Распределение оборудования по статусам" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="#1E293B"/>

        <TextBlock x:Name="txtNoData" Grid.Row="1" Text="Нет данных для отображения аналитики" FontSize="18" 
                   Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>

        <Border x:Name="ChartBorder" Grid.Row="1" Background="White" CornerRadius="8" Padding="20">
            <lvc:PieChart Series="{Binding StatusSeries}" LegendPosition="Right" />
        </Border>
    </Grid>
</Page>
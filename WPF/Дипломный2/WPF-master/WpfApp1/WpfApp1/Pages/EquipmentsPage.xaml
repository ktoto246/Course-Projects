<Page x:Class="WpfApp1.Pages.EquipmentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Оборудование">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Управление оборудованием" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>


        <Border Grid.Row="1" Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderLight}" x:Name="AddPanel" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Добавление нового оборудования" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"/>
                
                <WrapPanel Margin="0,0,0,15">
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Инв. №" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtInventoryNumber" Width="120"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Название" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtName" Width="180"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Серийный" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtSerialNumber" Width="140"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Цена" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtPrice" Width="100"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Дата покупки" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <DatePicker x:Name="dpPurchaseDate" Width="130"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Категория" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <ComboBox x:Name="cmbCategory" Width="150" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Статус" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <ComboBox x:Name="cmbStatus" Width="130" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Сотрудник" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <ComboBox x:Name="cmbEmployee" Width="170" DisplayMemberPath="FullName" SelectedValuePath="Id"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Локация" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtLocation" Width="120"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Примечание" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtNotes" Width="200"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Поставщик" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtSupplier" Width="150"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Срок службы (лет)" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtServiceLife" Width="100"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Конец гарантии" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <DatePicker x:Name="dpWarranty" Width="130"/>
                    </StackPanel>
                </WrapPanel>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Добавить" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="BtnAdd_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        
        <Border Grid.Row="2" Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <Grid>
                    <WrapPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Поиск" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                            <TextBox x:Name="txtSearch" Width="200" TextChanged="Filter_Changed" ToolTip="Имя или Инв. №"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Фильтр: Категория" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                            <ComboBox x:Name="cmbFilterCategory" Width="150" DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="Filter_Changed"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Фильтр: Статус" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                            <ComboBox x:Name="cmbFilterStatus" Width="150" DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="Filter_Changed"/>
                        </StackPanel>
                        
                        <Button Content="Сбросить" Margin="0,21,15,0" Click="BtnResetFilters_Click"/>
                    </WrapPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Button Content="Списать" Style="{StaticResource DangerButton}" Margin="0,0,10,0" Click="BtnDelete_Click" x:Name="BtnDelete"/>
                        <Button Content="Сохранить" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="BtnSave_Click" x:Name="BtnSave"/>
                        <Button Content="Экспорт в Excel" Style="{StaticResource SuccessButton}" Click="BtnExportExcel_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        
        <Border Grid.Row="3" Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="1">
            <DataGrid x:Name="EquipmentsGrid" AutoGenerateColumns="False" SelectionMode="Single" CanUserAddRows="False" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Инв. №" Binding="{Binding InventoryNumber}" Width="80"/>
                    <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="150"/>
                    <DataGridTextColumn Header="Серийный №" Binding="{Binding SerialNumber}" Width="120"/>
                    <DataGridComboBoxColumn x:Name="colCategory" Header="Категория" SelectedValueBinding="{Binding CategoryId, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="Name" SelectedValuePath="Id" Width="130"/>
                    <DataGridComboBoxColumn x:Name="colStatus" Header="Статус" SelectedValueBinding="{Binding StatusId, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="Name" SelectedValuePath="Id" Width="100"/>
                    <DataGridComboBoxColumn x:Name="colEmployee" Header="Ответственный" SelectedValueBinding="{Binding EmployeeId, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="FullName" SelectedValuePath="Id" Width="150"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=\{0:N2\}}" Width="70"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding PurchaseDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="80"/>
                    <DataGridTextColumn Header="Локация" Binding="{Binding Location}" Width="100"/>
                    <DataGridTextColumn Header="Примечание" Binding="{Binding Notes}" Width="150"/>
                    <DataGridTextColumn Header="Сумма ремонтов" Binding="{Binding TotalRepairCost, StringFormat=\{0:N2\}}" IsReadOnly="True" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>


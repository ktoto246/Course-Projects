<Page x:Class="WpfApp1.Pages.WorkloadAnalyticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="Распределение техники">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Распределение оборудования по сотрудникам" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <WrapPanel Grid.Row="1" Margin="0,0,0,20">
            <Border Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,15,10" Width="220">
                <StackPanel>
                    <TextBlock Text="Всего на балансе" Foreground="{StaticResource TextSecondary}" FontSize="14"/>
                    <TextBlock x:Name="txtTotalEquip" Text="0 шт." FontSize="24" FontWeight="Bold" Margin="0,5,0,0" Foreground="#2b3b4c"/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,15,10" Width="220">
                <StackPanel>
                    <TextBlock Text="Сейчас в ремонте" Foreground="{StaticResource TextSecondary}" FontSize="14"/>
                    <TextBlock x:Name="txtInRepair" Text="0 шт." FontSize="24" FontWeight="Bold" Margin="0,5,0,0" Foreground="#d9534f"/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,15,10" Width="280">
                <StackPanel>
                    <TextBlock Text="Общая стоимость фонда" Foreground="{StaticResource TextSecondary}" FontSize="14"/>
                    <TextBlock x:Name="txtTotalValue" Text="0,00 ₽" FontSize="24" FontWeight="Bold" Margin="0,5,0,0" Foreground="#5cb85c"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <TextBlock x:Name="txtNoData" Grid.Row="2" Text="Нет данных для отображения" 
                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                   FontSize="18" Foreground="Gray" Visibility="Collapsed"/>

        <Border x:Name="ChartBorder" Grid.Row="2" Background="White" CornerRadius="8" Padding="20">
            <lvc:CartesianChart Series="{Binding WorkloadSeries}" YAxes="{Binding YAxes}" 
                                TooltipPosition="Hidden" AnimationsSpeed="0" />
        </Border>
    </Grid>
</Page>
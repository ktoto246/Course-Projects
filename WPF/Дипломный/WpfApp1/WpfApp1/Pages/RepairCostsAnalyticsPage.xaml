<Page x:Class="WpfApp1.Pages.RepairCostsAnalyticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="Динамика расходов на ремонт">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Динамика расходов на ремонт" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="20">
            <lvc:CartesianChart
                Series="{Binding RepairSeries}"
                XAxes="{Binding XAxes}"
                YAxes="{Binding YAxes}"
                ZoomMode="None" 
                TooltipPosition="Top">
            </lvc:CartesianChart>
        </Border>
    </Grid>
</Page>
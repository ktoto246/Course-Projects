<Page x:Class="WpfApp1.Pages.StatusesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Справочник статусов">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Справочник статусов" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>


        <Border Grid.Row="1" Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderLight}" x:Name="AddPanel" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Управление статусами" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"/>
                
                <WrapPanel Margin="0,0,0,15" VerticalAlignment="Bottom">
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Название статуса" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtName" Width="250"/>
                    </StackPanel>
                    
                    <Button Content="Добавить" Style="{StaticResource PrimaryButton}" Margin="0,0,0,10" VerticalAlignment="Bottom" Height="34" Click="BtnAdd_Click"/>
                </WrapPanel>

                <Separator Margin="0,10,0,15" Background="{StaticResource BorderLight}"/>
                
                <Grid>
                    <WrapPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Поиск" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                            <TextBox x:Name="txtSearch" Width="250" TextChanged="Filter_Changed"/>
                        </StackPanel>
                    </WrapPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Button Content="Удалить" Style="{StaticResource DangerButton}" Margin="0,0,10,0" Click="BtnDelete_Click" Name="BtnDelete"/>
                        <Button Content="Сохранить" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="BtnSave_Click" Name="BtnSave"/>
                        <Button Content="Экспорт в Excel" Style="{StaticResource SuccessButton}" Click="BtnExportExcel_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        
        <Border Grid.Row="2" Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="1">
            <DataGrid x:Name="StatusesGrid" AutoGenerateColumns="False" SelectionMode="Single" CanUserAddRows="False" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Код" Binding="{Binding Id}" IsReadOnly="True" Width="80"/>
                    <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>


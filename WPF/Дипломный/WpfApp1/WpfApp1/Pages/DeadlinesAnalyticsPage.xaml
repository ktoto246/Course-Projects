<Page x:Class="WpfApp1.Pages.DeadlinesAnalyticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Контроль сроков">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Техника с истекающим сроком гарантии или службы" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
        <DataGrid x:Name="DeadlinesGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Инв. №" Binding="{Binding InventoryNumber}" Width="100"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Гарантия до" Binding="{Binding WarrantyExpireDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="120"/>
                <DataGridTextColumn Header="Поставщик" Binding="{Binding Supplier}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
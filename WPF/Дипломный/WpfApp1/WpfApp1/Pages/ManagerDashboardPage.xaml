<Page x:Class="WpfApp1.Pages.ManagerDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      Title="Дашборд Менеджера" Background="#F8FAFC">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Выручка сегодня" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtRevenueToday" Text="0 ₽" FontSize="32" FontWeight="Bold" Foreground="#10B981" Margin="0,5,0,0"/>
                    <TextBlock x:Name="txtCountToday" Text="0 услуг" FontSize="13" Foreground="#94A3B8" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15" Margin="10,0,10,0" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Выручка за месяц" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtRevenueMonth" Text="0 ₽" FontSize="32" FontWeight="Bold" Foreground="#1E293B" Margin="0,5,0,0"/>
                    <TextBlock x:Name="txtCountMonth" Text="0 услуг" FontSize="13" Foreground="#94A3B8" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="15" Margin="10,0,10,0" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Партий без услуг" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtNoServices" Text="0" FontSize="32" FontWeight="Bold" Foreground="#F59E0B" Margin="0,5,0,0"/>
                    <TextBlock Text="ждут оформления" FontSize="13" Foreground="#94A3B8" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Background="White" CornerRadius="8" Padding="15" Margin="10,0,0,0" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Средний чек" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtAvgCheck" Text="0 ₽" FontSize="32" FontWeight="Bold" Foreground="#3B82F6" Margin="0,5,0,0"/>
                    <TextBlock Text="за партию в этом месяце" FontSize="13" Foreground="#94A3B8" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,10,0" BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Выручка по видам услуг" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>
                    <lvc:PieChart x:Name="pieChartServices" Grid.Row="1" InnerRadius="40" LegendLocation="Right" Height="200"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20" Margin="10,0,0,0" BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Топ клиентов по выручке" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>
                    <ItemsControl x:Name="icTopClients" Grid.Row="1" VerticalAlignment="Center">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ClientName}" FontSize="14" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <ProgressBar Grid.Column="1" Value="{Binding Revenue}" Maximum="{Binding MaxRevenue}" Height="12" BorderThickness="0" Background="#F1F5F9" Foreground="#8B5CF6" Margin="10,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding RevenueText}" FontSize="14" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Выручка по дням — текущий месяц" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>
                <lvc:CartesianChart x:Name="lineChartRevenue" Grid.Row="1">
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis x:Name="axisXDays" Title="Дни месяца" LabelsRotation="0"/>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="Сумма (₽)" MinValue="0" LabelFormatter="{Binding CurrencyFormatter}"/>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </Grid>
        </Border>
    </Grid>
</Page>
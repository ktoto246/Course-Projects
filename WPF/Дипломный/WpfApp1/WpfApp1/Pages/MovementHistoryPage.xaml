<Page x:Class="WpfApp1.Pages.MovementHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Журнал перемещений">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Журнал перемещений" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderLight}" x:Name="AddPanel" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Добавить запись о перемещении" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"/>

                <WrapPanel Margin="0,0,0,15">
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Оборудование" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <ComboBox x:Name="cmbEquipment" Width="200" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Передал" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <ComboBox x:Name="cmbFromEmployee" Width="180" DisplayMemberPath="FullName" SelectedValuePath="Id"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Принял" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <ComboBox x:Name="cmbToEmployee" Width="180" DisplayMemberPath="FullName" SelectedValuePath="Id"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Дата" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <DatePicker x:Name="dpTransferDate" Width="130"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Причина" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtReason" Width="200"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Новое расположение (кабинет)" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <ComboBox x:Name="cmbNewCabinet" Width="180" DisplayMemberPath="Number" SelectedValuePath="Id"/>
                    </StackPanel>
                </WrapPanel>

                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="Добавить" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="BtnAdd_Click"/>
                    </StackPanel>
                </Grid>

                <Separator Margin="0,15,0,15" Background="{StaticResource BorderLight}"/>

                <Grid>
                    <WrapPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Поиск" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                            <TextBox x:Name="txtSearch" Width="250" TextChanged="Filter_Changed" ToolTip="Поиск по журналу"/>
                        </StackPanel>
                    </WrapPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Button Content="Удалить" Style="{StaticResource DangerButton}" Margin="0,0,10,0" Click="BtnDelete_Click" x:Name="BtnDelete"/>
                        <Button Content="Экспорт в Excel" Style="{StaticResource SuccessButton}" Click="BtnExportExcel_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="1">
            <DataGrid x:Name="MovementsGrid" AutoGenerateColumns="False" SelectionMode="Single" CanUserAddRows="False" BorderThickness="0" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridComboBoxColumn x:Name="colEquipment" Header="Оборудование" SelectedValueBinding="{Binding EquipmentId, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="Name" SelectedValuePath="Id" Width="180"/>
                    <DataGridComboBoxColumn x:Name="colFromEmployee" Header="Передал" SelectedValueBinding="{Binding FromEmployeeId, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="FullName" SelectedValuePath="Id" Width="150"/>
                    <DataGridComboBoxColumn x:Name="colToEmployee" Header="Принял" SelectedValueBinding="{Binding ToEmployeeId, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="FullName" SelectedValuePath="Id" Width="150"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding TransferDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="100"/>
                    <DataGridTextColumn Header="Причина" Binding="{Binding Reason}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
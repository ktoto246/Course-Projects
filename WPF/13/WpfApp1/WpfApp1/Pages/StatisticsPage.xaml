<Page x:Class="WpfApp1.Pages.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="Статистика" Background="White">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Аналитика работы" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Специальности" Margin="5">
                <lvc:PieChart x:Name="PieChartSpecializations" LegendPosition="Right"/>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="Врачи" Margin="5">
                <lvc:CartesianChart x:Name="BarChartDoctors"/>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="2" Header="Динамика (30 дней)" Margin="5">
            <lvc:CartesianChart x:Name="LineChartDynamics"/>
        </GroupBox>
    </Grid>
</Page>
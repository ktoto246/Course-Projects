<Page x:Class="WpfApp1.ClientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ClientsPage" Background="#1E1E1E">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtSearch" Height="35" Margin="0,0,20,0" Padding="10,0" 
                         VerticalContentAlignment="Center" FontSize="14" 
                         TextChanged="TxtSearch_TextChanged"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnAdd" Content="Добавить" Width="120" Height="35" Margin="0,0,10,0" 
                            Background="#68217A" Foreground="White" BorderThickness="0" Click="BtnAdd_Click"/>
                    <Button x:Name="BtnEdit" Content="Изменить" Width="120" Height="35" Margin="0,0,10,0" 
                            Background="#007ACC" Foreground="White" BorderThickness="0" Click="BtnEdit_Click"/>
                    <Button x:Name="BtnDelete" Content="Удалить" Width="120" Height="35" 
                            Background="#AC193D" Foreground="White" BorderThickness="0" Click="BtnDelete_Click"/>
                </StackPanel>
            </Grid>

            <DataGrid x:Name="ClientsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                      CanUserSortColumns="True" SelectionMode="Single"
                      Background="#2D2D30" Foreground="Black" RowBackground="White" AlternatingRowBackground="#E6E6E6"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ClientID}" Width="50"/>
                    <DataGridTextColumn Header="Компания" Binding="{Binding CompanyName}" Width="*"/>
                    <DataGridTextColumn Header="ИНН" Binding="{Binding INN}" Width="150"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="150"/>
                    <DataGridTextColumn Header="Город" Binding="{Binding City}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border x:Name="EditPanel" Grid.Column="1" Width="300" Background="#252526" CornerRadius="8" Visibility="Collapsed" Padding="20">
            <StackPanel>
                <TextBlock x:Name="PanelTitle" Text="Добавление" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <TextBlock Text="Компания:" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtCompanyName" Height="30" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="ИНН:" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtINN" Height="30" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Телефон:" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtPhone" Height="30" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Город:" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtCity" Height="30" Margin="0,0,0,25" Padding="5"/>

                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnSave" Content="Сохранить" Width="125" Height="35" Background="#68217A" Foreground="White" BorderThickness="0" Click="BtnSave_Click"/>
                    <Button x:Name="BtnCancel" Content="Отмена" Width="125" Height="35" Background="#3E3E42" Foreground="White" BorderThickness="0" Click="BtnCancel_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
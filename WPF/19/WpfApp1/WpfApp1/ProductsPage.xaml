<Page x:Class="WpfApp1.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ProductsPage" Background="#1E1E1E">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtSearch" Height="35" Margin="0,0,20,0" Padding="10,0" 
                         VerticalContentAlignment="Center" FontSize="14" 
                         TextChanged="TxtSearch_TextChanged"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnAdd" Content="Добавить" Width="120" Height="35" Margin="0,0,10,0" 
                            Background="#68217A" Foreground="White" BorderThickness="0" Click="BtnAdd_Click"/>
                    <Button x:Name="BtnEdit" Content="Изменить" Width="120" Height="35" Margin="0,0,10,0" 
                            Background="#007ACC" Foreground="White" BorderThickness="0" Click="BtnEdit_Click"/>
                    <Button x:Name="BtnDelete" Content="Удалить" Width="120" Height="35" 
                            Background="#AC193D" Foreground="White" BorderThickness="0" Click="BtnDelete_Click"/>
                </StackPanel>
            </Grid>

            <DataGrid x:Name="ProductsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                      CanUserSortColumns="True" SelectionMode="Single"
                      Background="#2D2D30" Foreground="Black" RowBackground="White" AlternatingRowBackground="#E6E6E6"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ProductID}" Width="50"/>
                    <DataGridTextColumn Header="Наименование" Binding="{Binding ModelName}" Width="*"/>
                    <DataGridTextColumn Header="Высота (м)" Binding="{Binding Height, StringFormat={}{0:F2}}" Width="100"/>
                    <DataGridTextColumn Header="Цена (руб)" Binding="{Binding Price, StringFormat={}{0:F2}}" Width="120"/>
                    <DataGridTextColumn Header="Остаток на складе" Binding="{Binding StockQuantity}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border x:Name="EditPanel" Grid.Column="1" Width="300" Background="#252526" CornerRadius="8" Visibility="Collapsed" Padding="20">
            <StackPanel>
                <TextBlock x:Name="PanelTitle" Text="Новый товар" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <TextBlock Text="Наименование ёлки:" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtModelName" Height="30" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Высота (в метрах):" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtHeight" Height="30" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Цена:" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtPrice" Height="30" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Количество на складе:" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtStock" Height="30" Margin="0,0,0,25" Padding="5"/>

                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnSave" Content="Сохранить" Width="125" Height="35" Background="#68217A" Foreground="White" BorderThickness="0" Click="BtnSave_Click"/>
                    <Button x:Name="BtnCancel" Content="Отмена" Width="125" Height="35" Background="#3E3E42" Foreground="White" BorderThickness="0" Click="BtnCancel_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
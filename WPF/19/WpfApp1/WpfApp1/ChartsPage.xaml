<Page x:Class="WpfApp1.ChartsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="ChartsPage" Background="#1E1E1E">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Аналитика продаж" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="Период с:" Foreground="#CCCCCC" VerticalAlignment="Center" FontSize="14" Margin="0,0,10,0"/>
            <DatePicker x:Name="DpStart" Width="130" Height="30" Margin="0,0,20,0"/>

            <TextBlock Text="по:" Foreground="#CCCCCC" VerticalAlignment="Center" FontSize="14" Margin="0,0,10,0"/>
            <DatePicker x:Name="DpEnd" Width="130" Height="30" Margin="0,0,20,0"/>

            <Button x:Name="BtnFilter" Content="Применить" Width="120" Height="30" Background="#68217A" Foreground="White" BorderThickness="0" Click="BtnFilter_Click"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#252526" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Топ продаваемых моделей (шт)" Foreground="#CCCCCC" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <lvc:PieChart Grid.Row="1" Series="{Binding PieSeries}" LegendPosition="Bottom"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#252526" CornerRadius="8" Padding="15" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Динамика выручки по дням (руб)" Foreground="#CCCCCC" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding LineSeries}" XAxes="{Binding XAxes}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
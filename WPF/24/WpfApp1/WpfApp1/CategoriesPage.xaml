<Page x:Class="WpfApp1.CategoriesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="CategoriesPage" Height="500" Width="650">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBox x:Name="TxtCategoryName" Width="250" Height="30" VerticalContentAlignment="Center" FontSize="14" Margin="0,0,10,0"/>
            <Button Content="Добавить" Width="100" Height="30" Background="#E30611" Foreground="White" FontWeight="Bold" Margin="0,0,5,0" Click="BtnAdd_Click"/>
            <Button Content="Изменить" Width="100" Height="30" Background="#FFB71B" Foreground="White" FontWeight="Bold" Margin="0,0,5,0" Click="BtnUpdate_Click"/>
            <Button Content="Удалить" Width="100" Height="30" Background="Black" Foreground="White" FontWeight="Bold" Click="BtnDelete_Click"/>
        </StackPanel>

        <DataGrid x:Name="DgCategories" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="DgCategories_SelectionChanged" FontSize="14" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="Название категории" Binding="{Binding Name}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
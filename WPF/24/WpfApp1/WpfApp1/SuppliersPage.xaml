<Page x:Class="WpfApp1.SuppliersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SuppliersPage" Height="500" Width="700">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Компания:" Width="75" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtCompanyName" Width="200" Height="30" VerticalContentAlignment="Center" FontSize="14" Margin="0,0,15,0"/>

            <TextBlock Text="Телефон:" Width="70" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtPhone" Width="130" Height="30" VerticalContentAlignment="Center" FontSize="14" Margin="0,0,15,0"/>

            <TextBlock Text="ИНН:" Width="40" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtInn" Width="120" Height="30" VerticalContentAlignment="Center" FontSize="14"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="Добавить" Width="100" Height="30" Background="#E30611" Foreground="White" FontWeight="Bold" Margin="0,0,5,0" Click="BtnAdd_Click"/>
            <Button Content="Изменить" Width="100" Height="30" Background="#FFB71B" Foreground="White" FontWeight="Bold" Margin="0,0,5,0" Click="BtnUpdate_Click"/>
            <Button Content="Удалить" Width="100" Height="30" Background="Black" Foreground="White" FontWeight="Bold" Click="BtnDelete_Click"/>
        </StackPanel>

        <DataGrid x:Name="DgSuppliers" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="DgSuppliers_SelectionChanged" FontSize="14" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название компании" Binding="{Binding CompanyName}" Width="*"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="150"/>
                <DataGridTextColumn Header="ИНН" Binding="{Binding Inn}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
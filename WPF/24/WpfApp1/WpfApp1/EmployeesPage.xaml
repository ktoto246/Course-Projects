<Page x:Class="WpfApp1.EmployeesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="EmployeesPage" Height="500" Width="650">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="ФИО:" Width="50" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtFullName" Width="250" Height="30" VerticalContentAlignment="Center" FontSize="14" Margin="0,0,15,0"/>

            <TextBlock Text="Должность:" Width="85" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtPosition" Width="200" Height="30" VerticalContentAlignment="Center" FontSize="14"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="Добавить" Width="100" Height="30" Background="#E30611" Foreground="White" FontWeight="Bold" Margin="0,0,5,0" Click="BtnAdd_Click"/>
            <Button Content="Изменить" Width="100" Height="30" Background="#FFB71B" Foreground="White" FontWeight="Bold" Margin="0,0,5,0" Click="BtnUpdate_Click"/>
            <Button Content="Удалить" Width="100" Height="30" Background="Black" Foreground="White" FontWeight="Bold" Click="BtnDelete_Click"/>
        </StackPanel>

        <DataGrid x:Name="DgEmployees" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="DgEmployees_SelectionChanged" FontSize="14" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
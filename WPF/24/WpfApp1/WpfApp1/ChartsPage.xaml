<Page x:Class="WpfApp1.ChartsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="ChartsPage" Height="500" Width="700">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Объем принятого товара по позициям" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <Button Content="Обновить данные" Width="150" Height="30" Background="#FFB71B" Foreground="White" FontWeight="Bold" Click="BtnRefresh_Click"/>
        </StackPanel>

        <lvc:CartesianChart x:Name="MainChart" Grid.Row="1" Series="{Binding Series}" XAxes="{Binding XAxes}" Background="White"/>
    </Grid>
</Page>
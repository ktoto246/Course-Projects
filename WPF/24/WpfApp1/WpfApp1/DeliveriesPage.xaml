<Page x:Class="WpfApp1.DeliveriesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="DeliveriesPage" Height="550" Width="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Дата:" Width="45" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
            <DatePicker x:Name="DpDeliveryDate" Width="130" Height="30" FontSize="14" VerticalContentAlignment="Center" Margin="0,0,15,0"/>

            <TextBlock Text="Кол-во:" Width="60" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtQuantity" Width="80" Height="30" VerticalContentAlignment="Center" FontSize="14" Margin="0,0,15,0"/>

            <TextBlock Text="Товар:" Width="55" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
            <ComboBox x:Name="CmbProducts" Width="250" Height="30" FontSize="14" VerticalContentAlignment="Center" DisplayMemberPath="Name" SelectedValuePath="Id"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Поставщик:" Width="85" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
            <ComboBox x:Name="CmbSuppliers" Width="200" Height="30" FontSize="14" VerticalContentAlignment="Center" DisplayMemberPath="CompanyName" SelectedValuePath="Id" Margin="0,0,15,0"/>

            <TextBlock Text="Сотрудник:" Width="85" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
            <ComboBox x:Name="CmbEmployees" Width="250" Height="30" FontSize="14" VerticalContentAlignment="Center" DisplayMemberPath="FullName" SelectedValuePath="Id"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="Добавить" Width="100" Height="30" Background="#E30611" Foreground="White" FontWeight="Bold" Margin="0,0,5,0" Click="BtnAdd_Click"/>
            <Button Content="Изменить" Width="100" Height="30" Background="#FFB71B" Foreground="White" FontWeight="Bold" Margin="0,0,5,0" Click="BtnUpdate_Click"/>
            <Button Content="Удалить" Width="100" Height="30" Background="Black" Foreground="White" FontWeight="Bold" Click="BtnDelete_Click"/>
        </StackPanel>

        <DataGrid x:Name="DgDeliveries" Grid.Row="3" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="DgDeliveries_SelectionChanged" FontSize="14" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding DeliveryDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="100"/>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="70"/>
                <DataGridTextColumn Header="Товар" Binding="{Binding Product.Name}" Width="180"/>
                <DataGridTextColumn Header="Поставщик" Binding="{Binding Supplier.CompanyName}" Width="150"/>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding Employee.FullName}" Width="180"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
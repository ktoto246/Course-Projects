<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Магнит Семейный - Учет" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#E30611" Grid.Column="0">
            <StackPanel Margin="10,20,10,10">
                <TextBlock Text="МАГНИТ" Foreground="White" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="СЕМЕЙНЫЙ" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <Button Content="Категории" Height="40" Margin="0,0,0,10" Background="White" Foreground="#E30611" FontSize="16" FontWeight="SemiBold" Click="BtnCategories_Click"/>
                <Button Content="Сотрудники" Height="40" Margin="0,0,0,10" Background="White" Foreground="#E30611" FontSize="16" FontWeight="SemiBold" Click="BtnEmployees_Click"/>
                <Button Content="Поставщики" Height="40" Margin="0,0,0,10" Background="White" Foreground="#E30611" FontSize="16" FontWeight="SemiBold" Click="BtnSuppliers_Click"/>
                <Button Content="Товары" Height="40" Margin="0,0,0,10" Background="White" Foreground="#E30611" FontSize="16" FontWeight="SemiBold" Click="BtnProducts_Click"/>
                <Button Content="Журнал приемки" Height="40" Margin="0,0,0,10" Background="White" Foreground="#E30611" FontSize="16" FontWeight="SemiBold" Click="BtnDeliveries_Click"/>

                <Button Content="Графики" Height="40" Margin="0,30,0,10" Background="#FFB71B" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0" Click="BtnCharts_Click"/>
            </StackPanel>
        </Border>

        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Background="#F5F5F5"/>
    </Grid>
</Window>
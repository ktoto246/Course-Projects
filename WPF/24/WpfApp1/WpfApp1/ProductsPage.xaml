<Page x:Class="WpfApp1.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ProductsPage" Height="500" Width="700">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Название:" Width="75" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtProductName" Width="250" Height="30" VerticalContentAlignment="Center" FontSize="14" Margin="0,0,15,0"/>

            <TextBlock Text="Категория:" Width="80" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
            <ComboBox x:Name="CmbCategories" Width="200" Height="30" FontSize="14" VerticalContentAlignment="Center" DisplayMemberPath="Name" SelectedValuePath="Id"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="Добавить" Width="100" Height="30" Background="#E30611" Foreground="White" FontWeight="Bold" Margin="0,0,5,0" Click="BtnAdd_Click"/>
            <Button Content="Изменить" Width="100" Height="30" Background="#FFB71B" Foreground="White" FontWeight="Bold" Margin="0,0,5,0" Click="BtnUpdate_Click"/>
            <Button Content="Удалить" Width="100" Height="30" Background="Black" Foreground="White" FontWeight="Bold" Click="BtnDelete_Click"/>
        </StackPanel>

        <DataGrid x:Name="DgProducts" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="DgProducts_SelectionChanged" FontSize="14" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название товара" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Category.Name}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
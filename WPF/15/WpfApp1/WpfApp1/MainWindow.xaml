<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="ООО Газрегион" Height="600" Width="900"
        Background="#1E1E1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Orientation="Horizontal" Margin="10" Background="#1E1E1E">
            <Button Content="Сварщики" Width="100" Margin="5" Click="OnNavigationClick"/>
            <Button Content="Трубопроводы" Width="100" Margin="5" Click="OnNavigationClick"/>
            <Button Content="Сварочные аппараты" Width="100" Margin="5" Click="OnNavigationClick"/>
            <Button Content="Сварные соединения" Width="100" Margin="5" Click="OnNavigationClick"/>
            <Button Content="Контроль" Width="100" Margin="5" Click="OnNavigationClick"/>
            <Button Content="Аналитика" Width="100" Margin="5" Click="AnalyticsClick"/>
        </StackPanel>
        
        <Frame Grid.Row="1" Name="MainFrame" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>

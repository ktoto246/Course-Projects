<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="ООО БМТК - АРМ Техосмотра" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#ECEFF1">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BDC3C7"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="25,15"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#34495E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1ABC9C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel>
                <TextBlock Text="ООО БМТК" 
                           Foreground="White" FontSize="26" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,30,0,10"/>
                <TextBlock Text="Пункт техосмотра" 
                           Foreground="#7F8C8D" FontSize="14" 
                           HorizontalAlignment="Center" Margin="0,0,0,40"/>
                
                <Button Content="Журнал осмотров" Style="{StaticResource MenuButtonStyle}" Click="NavInspections_Click"/>
                <Button Content="Клиенты" Style="{StaticResource MenuButtonStyle}" Click="NavClients_Click"/>
                <Button Content="Транспорт" Style="{StaticResource MenuButtonStyle}" Click="NavVehicles_Click"/>
                <Button Content="Прайс-лист" Style="{StaticResource MenuButtonStyle}" Click="NavServices_Click"/>
                <Button Content="Сотрудники" Style="{StaticResource MenuButtonStyle}" Click="NavEmployees_Click"/>
                <Button Content="Статистика" Style="{StaticResource MenuButtonStyle}" Click="NavStats_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White" Margin="20" CornerRadius="5">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="1"/>
            </Border.Effect>
            
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" ClipToBounds="True"/>
        </Border>
    </Grid>
</Window>

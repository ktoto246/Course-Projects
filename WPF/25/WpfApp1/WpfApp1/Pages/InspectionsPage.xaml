<Page x:Class="WpfApp1.Pages.InspectionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Журнал осмотров" Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="InspectionsGrid" Grid.Row="0" AutoGenerateColumns="False" 
                  CanUserAddRows="False" IsReadOnly="True" 
                  SelectionChanged="InspectionsGrid_SelectionChanged"
                  Background="White" BorderBrush="#BDC3C7" BorderThickness="1"
                  RowHeight="30" ColumnHeaderHeight="35">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding InspectionDate, StringFormat=dd.MM.yyyy HH:mm}" Width="130"/>
                <DataGridTextColumn Header="Гос. номер" Binding="{Binding Vehicle.RegNumber}" Width="100"/>
                <DataGridTextColumn Header="Услуга" Binding="{Binding Service.Name}" Width="250"/>
                <DataGridTextColumn Header="Диагност" Binding="{Binding Employee.FullName}" Width="150"/>
                <DataGridCheckBoxColumn Header="Пройден" Binding="{Binding IsPassed}" Width="80"/>
                <DataGridTextColumn Header="Комментарий" Binding="{Binding Comments}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#BDC3C7" BorderThickness="1" 
                Margin="0,20,0,0" Padding="15" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Оформление техосмотра" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Автомобиль:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="CmbVehicle" Grid.Column="1" Height="25" Margin="0,0,20,0" 
                              DisplayMemberPath="RegNumber" SelectedValuePath="Id"/>

                    <TextBlock Text="Услуга:" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="CmbService" Grid.Column="3" Height="25" Margin="0,0,20,0" 
                              DisplayMemberPath="Name" SelectedValuePath="Id"/>

                    <TextBlock Text="Диагност:" Grid.Column="4" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="CmbEmployee" Grid.Column="5" Height="25" 
                              DisplayMemberPath="FullName" SelectedValuePath="Id"/>

                    <TextBlock Text="Дата и время:" Grid.Row="2" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,20,0">
                        <DatePicker x:Name="DpDate" Width="120" Height="25"/>
                        <TextBox x:Name="TxtTime" Width="60" Height="25" Margin="5,0,0,0" ToolTip="Время (ЧЧ:ММ)" Text="12:00"/>
                    </StackPanel>

                    <TextBlock Text="Статус:" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <CheckBox x:Name="ChkIsPassed" Grid.Row="2" Grid.Column="3" Content="Техосмотр пройден" 
                              VerticalAlignment="Center" Margin="0,0,20,0"/>

                    <TextBlock Text="Комментарий:" Grid.Row="4" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtComments" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="5" Height="50" 
                             TextWrapping="Wrap" AcceptsReturn="True" Padding="2"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="Добавить" Width="100" Height="30" Margin="10,0,0,0" 
                            Background="#2ECC71" Foreground="White" BorderThickness="0" Click="BtnAdd_Click"/>
                    <Button Content="Изменить" Width="100" Height="30" Margin="10,0,0,0" 
                            Background="#F39C12" Foreground="White" BorderThickness="0" Click="BtnEdit_Click"/>
                    <Button Content="Удалить" Width="100" Height="30" Margin="10,0,0,0" 
                            Background="#E74C3C" Foreground="White" BorderThickness="0" Click="BtnDelete_Click"/>
                    <Button Content="Очистить" Width="100" Height="30" Margin="10,0,0,0" 
                            Background="#95A5A6" Foreground="White" BorderThickness="0" Click="BtnClear_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>

<Page x:Class="WpfApp1.Pages.VehiclesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Транспорт" Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="VehiclesGrid" Grid.Row="0" AutoGenerateColumns="False" 
                  CanUserAddRows="False" IsReadOnly="True" 
                  SelectionChanged="VehiclesGrid_SelectionChanged"
                  Background="White" BorderBrush="#BDC3C7" BorderThickness="1"
                  RowHeight="30" ColumnHeaderHeight="35">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                <DataGridTextColumn Header="Владелец" Binding="{Binding Client.FullName}" Width="200"/>
                <DataGridTextColumn Header="Марка" Binding="{Binding Brand}" Width="100"/>
                <DataGridTextColumn Header="Модель" Binding="{Binding Model}" Width="100"/>
                <DataGridTextColumn Header="Гос. Номер" Binding="{Binding RegNumber}" Width="100"/>
                <DataGridTextColumn Header="VIN" Binding="{Binding VIN}" Width="150"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#BDC3C7" BorderThickness="1" 
                Margin="0,20,0,0" Padding="15" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Управление транспортом" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Владелец:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="CmbClient" Grid.Column="1" Height="25" Margin="0,0,20,0" 
                              DisplayMemberPath="FullName" SelectedValuePath="Id"/>

                    <TextBlock Text="Марка:" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtBrand" Grid.Column="3" Height="25" Margin="0,0,20,0" Padding="2"/>

                    <TextBlock Text="Модель:" Grid.Column="4" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtModel" Grid.Column="5" Height="25" Padding="2"/>

                    <TextBlock Text="VIN код:" Grid.Row="2" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtVIN" Grid.Row="2" Grid.Column="1" Height="25" Margin="0,0,20,0" Padding="2"/>

                    <TextBlock Text="Гос. номер:" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtRegNumber" Grid.Row="2" Grid.Column="3" Height="25" Margin="0,0,20,0" Padding="2"/>

                    <TextBlock Text="Категория:" Grid.Row="2" Grid.Column="4" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="CmbCategory" Grid.Row="2" Grid.Column="5" Height="25">
                        <ComboBoxItem Content="M1 (Легковые)" IsSelected="True"/>
                        <ComboBoxItem Content="M2 (Автобусы до 5т)"/>
                        <ComboBoxItem Content="M3 (Автобусы свыше 5т)"/>
                        <ComboBoxItem Content="N1 (Грузовые до 3.5т)"/>
                        <ComboBoxItem Content="N2 (Грузовые 3.5 - 12т)"/>
                    </ComboBox>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="Добавить" Width="100" Height="30" Margin="10,0,0,0" 
                            Background="#2ECC71" Foreground="White" BorderThickness="0" Click="BtnAdd_Click"/>
                    <Button Content="Изменить" Width="100" Height="30" Margin="10,0,0,0" 
                            Background="#F39C12" Foreground="White" BorderThickness="0" Click="BtnEdit_Click"/>
                    <Button Content="Удалить" Width="100" Height="30" Margin="10,0,0,0" 
                            Background="#E74C3C" Foreground="White" BorderThickness="0" Click="BtnDelete_Click"/>
                    <Button Content="Очистить" Width="100" Height="30" Margin="10,0,0,0" 
                            Background="#95A5A6" Foreground="White" BorderThickness="0" Click="BtnClear_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
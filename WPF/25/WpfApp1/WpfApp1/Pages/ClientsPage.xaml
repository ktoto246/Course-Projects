<Page x:Class="WpfApp1.Pages.ClientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Клиенты" Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="ClientsGrid" Grid.Row="0" AutoGenerateColumns="False" 
                  CanUserAddRows="False" IsReadOnly="True" 
                  SelectionChanged="ClientsGrid_SelectionChanged"
                  Background="White" BorderBrush="#BDC3C7" BorderThickness="1"
                  RowHeight="30" ColumnHeaderHeight="35">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="ФИО Клиента" Binding="{Binding FullName}" Width="300"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="150"/>
                <DataGridTextColumn Header="ВУ / Документ" Binding="{Binding DriverLicense}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#BDC3C7" BorderThickness="1" 
                Margin="0,20,0,0" Padding="15" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Управление клиентом" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="ФИО:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtFullName" Grid.Column="1" Height="25" Margin="0,0,20,0" Padding="2" ToolTip="Обязательное поле"/>

                    <TextBlock Text="Телефон:" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtPhone" Grid.Column="3" Height="25" Margin="0,0,20,0" Padding="2" ToolTip="Формат: +7XXXXXXXXXX или 8XXXXXXXXXX"/>

                    <TextBlock Text="Документ (ВУ):" Grid.Column="4" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtDriverLicense" Grid.Column="5" Height="25" Padding="2" ToolTip="Права или паспорт"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="Добавить" Width="100" Height="30" Margin="10,0,0,0" 
                            Background="#2ECC71" Foreground="White" BorderThickness="0" Click="BtnAdd_Click"/>
                    <Button Content="Изменить" Width="100" Height="30" Margin="10,0,0,0" 
                            Background="#F39C12" Foreground="White" BorderThickness="0" Click="BtnEdit_Click"/>
                    <Button Content="Удалить" Width="100" Height="30" Margin="10,0,0,0" 
                            Background="#E74C3C" Foreground="White" BorderThickness="0" Click="BtnDelete_Click"/>
                    <Button Content="Очистить" Width="100" Height="30" Margin="10,0,0,0" 
                            Background="#95A5A6" Foreground="White" BorderThickness="0" Click="BtnClear_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
<Page x:Class="WpfApp1.Pages.ClientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Клиенты" Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="0,0,0,15" Margin="0,0,0,15">
            <TextBlock Text="Справочник клиентов" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold"/>
                    <TextBox x:Name="SearchTextBox" Width="240" TextChanged="SearchTextBox_TextChanged"/>
                </StackPanel>
            </Grid>

            <DataGrid x:Name="ClientsGrid" Grid.Row="1" Grid.Column="0" AutoGenerateColumns="False" 
                      IsReadOnly="True" SelectionMode="Single" SelectionChanged="ClientsGrid_SelectionChanged"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E0E0E0"
                      BorderThickness="1" BorderBrush="#D1D1D1" RowHeight="35" Margin="0,0,20,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ID_Клиента}" Width="50"/>
                    <DataGridTextColumn Header="Название компании" Binding="{Binding Название_Компании}" Width="*"/>
                    <DataGridTextColumn Header="ИНН" Binding="{Binding ИНН}" Width="150"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Контактный_Телефон}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="1" Grid.Column="1" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" Padding="20">
                <StackPanel>
                    <TextBlock Text="Карточка клиента" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                    <TextBlock Text="Название компании:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtName" Padding="5" Margin="0,0,0,15" FontSize="14"/>

                    <TextBlock Text="ИНН:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtINN" Padding="5" Margin="0,0,0,15" FontSize="14"/>

                    <TextBlock Text="Контактный телефон:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtPhone" Padding="5" Margin="0,0,0,25" FontSize="14"/>

                    <Button Content="Сохранить" Click="SaveBtn_Click" Background="#28A745" Foreground="White" BorderThickness="0" Padding="10" Margin="0,0,0,10" Cursor="Hand" FontWeight="Bold"/>
                    <Button Content="Очистить (Новый)" Click="ClearBtn_Click" Background="#6C757D" Foreground="White" BorderThickness="0" Padding="10" Margin="0,0,0,10" Cursor="Hand"/>
                    <Button Content="Удалить" Click="DeleteBtn_Click" Background="#DC3545" Foreground="White" BorderThickness="0" Padding="10" Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>

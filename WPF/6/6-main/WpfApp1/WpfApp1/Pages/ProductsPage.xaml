<Page x:Class="WpfApp1.Pages.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Нефтепродукты" Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="0,0,0,15" Margin="0,0,0,15">
            <TextBlock Text="Справочник нефтепродуктов" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold"/>
                    <TextBox x:Name="SearchTextBox" Width="240" TextChanged="SearchTextBox_TextChanged"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="Класс опасности:" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold"/>
                    <ComboBox x:Name="DangerClassFilterComboBox" Width="120" SelectionChanged="DangerClassFilterComboBox_SelectionChanged"/>
                </StackPanel>
            </Grid>

            <DataGrid x:Name="ProductsGrid" Grid.Row="1" Grid.Column="0" AutoGenerateColumns="False" 
                      IsReadOnly="True" SelectionMode="Single" SelectionChanged="ProductsGrid_SelectionChanged"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E0E0E0"
                      BorderThickness="1" BorderBrush="#D1D1D1" RowHeight="35" Margin="0,0,20,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ID_Продукта}" Width="50"/>
                    <DataGridTextColumn Header="Название" Binding="{Binding Название}" Width="*"/>
                    <DataGridTextColumn Header="Класс опасности" Binding="{Binding Класс_Опасности}" Width="120"/>
                    <DataGridTextColumn Header="Цена за тонну" Binding="{Binding Цена_За_Тонну, StringFormat={}{0:N2}}" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="1" Grid.Column="1" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" Padding="20">
                <StackPanel>
                    <TextBlock Text="Карточка продукта" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                    <TextBlock Text="Название:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtName" Padding="5" Margin="0,0,0,15" FontSize="14"/>

                    <TextBlock Text="Класс опасности (число):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtDangerClass" Padding="5" Margin="0,0,0,15" FontSize="14"/>

                    <TextBlock Text="Цена за тонну:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtPrice" Padding="5" Margin="0,0,0,25" FontSize="14"/>

                    <Button Content="Сохранить" Click="SaveBtn_Click" Background="#28A745" Foreground="White" BorderThickness="0" Padding="10" Margin="0,0,0,10" Cursor="Hand" FontWeight="Bold"/>
                    <Button Content="Очистить (Новый)" Click="ClearBtn_Click" Background="#6C757D" Foreground="White" BorderThickness="0" Padding="10" Margin="0,0,0,10" Cursor="Hand"/>
                    <Button Content="Удалить" Click="DeleteBtn_Click" Background="#DC3545" Foreground="White" BorderThickness="0" Padding="10" Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
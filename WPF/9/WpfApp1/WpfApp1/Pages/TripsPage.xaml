<Page x:Class="WpfApp1.Pages.TripsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Журнал пробега" Background="White">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Запись путевого листа" Margin="0,0,0,15" Padding="10">
            <StackPanel>
                <UniformGrid Columns="3" Margin="0,0,0,10">
                    <StackPanel Margin="5,0">
                        <TextBlock Text="Автомобиль:"/>
                        <ComboBox x:Name="CmbVehicle" Padding="3"/>
                    </StackPanel>
                    <StackPanel Margin="5,0">
                        <TextBlock Text="Дата поездки:"/>
                        <DatePicker x:Name="DpTripDate"/>
                    </StackPanel>
                    <StackPanel Margin="5,0">
                        <TextBlock Text="Пройдено (км):"/>
                        <TextBox x:Name="TxtDistance" Padding="3"/>
                    </StackPanel>
                    <StackPanel Margin="5,10,5,0">
                        <TextBlock Text="Водитель:"/>
                        <TextBox x:Name="TxtDriver" Padding="3"/>
                    </StackPanel>
                    <StackPanel Margin="5,10,5,0">
                        <TextBlock Text="Путевой лист:"/>
                        <TextBox x:Name="TxtWaybill" Padding="3"/>
                    </StackPanel>
                </UniformGrid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Сохранить" Click="SaveBtn_Click" Width="100" Margin="5" Background="#28A745" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
                    <Button Content="Новый" Click="ClearBtn_Click" Width="100" Margin="5" Background="#6C757D" Foreground="White" Cursor="Hand"/>
                    <Button Content="Удалить" Click="DeleteBtn_Click" Width="100" Margin="5" Background="#DC3545" Foreground="White" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <DataGrid x:Name="TripsGrid" Grid.Row="1" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionMode="Single" 
                  SelectionChanged="TripsGrid_SelectionChanged" RowHeight="30"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding IdЗаписи}" Width="50"/>
                <DataGridTextColumn Header="Авто (Гос. Номер)" Binding="{Binding IdАвтоNavigation.ГосНомер}" Width="150" FontWeight="Bold"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding ДатаПоездки, StringFormat=\{0:dd.MM.yyyy\}}" Width="100"/>
                <DataGridTextColumn Header="Пробег" Binding="{Binding ПройденоКм}" Width="80"/>
                <DataGridTextColumn Header="Водитель" Binding="{Binding Водитель}" Width="*"/>
                <DataGridTextColumn Header="Пут. Лист" Binding="{Binding ПутевойЛист}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
<Page x:Class="WpfApp1.Pages.RepairsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Учет ремонтов" Background="White">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Данные по ТО и ремонту" Margin="0,0,0,15" Padding="10">
            <StackPanel>
                <UniformGrid Columns="3" Margin="0,0,0,10">
                    <StackPanel Margin="5,0">
                        <TextBlock Text="Автомобиль:"/>
                        <ComboBox x:Name="CmbVehicle" Padding="3"/>
                    </StackPanel>
                    <StackPanel Margin="5,0">
                        <TextBlock Text="Тип ремонта/ТО:"/>
                        <TextBox x:Name="TxtRepairType" Padding="3"/>
                    </StackPanel>
                    <StackPanel Margin="5,0">
                        <TextBlock Text="Статус:"/>
                        <ComboBox x:Name="CmbStatus" Padding="3"/>
                    </StackPanel>
                    <StackPanel Margin="5,10,5,0">
                        <TextBlock Text="План. Пробег:"/>
                        <TextBox x:Name="TxtPlanMileage" Padding="3"/>
                    </StackPanel>
                    <StackPanel Margin="5,10,5,0">
                        <TextBlock Text="План. Дата:"/>
                        <DatePicker x:Name="DpPlanDate"/>
                    </StackPanel>
                    <StackPanel Margin="5,10,5,0">
                        <TextBlock Text="Факт. Дата:"/>
                        <DatePicker x:Name="DpActualDate"/>
                    </StackPanel>
                </UniformGrid>

                <StackPanel Margin="5,10,5,10">
                    <TextBlock Text="Описание:"/>
                    <TextBox x:Name="TxtDescription" Padding="3" Height="40" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить" Click="SaveBtn_Click" Width="100" Margin="5" Background="#28A745" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
                    <Button Content="Новый" Click="ClearBtn_Click" Width="100" Margin="5" Background="#6C757D" Foreground="White" Cursor="Hand"/>
                    <Button Content="Удалить" Click="DeleteBtn_Click" Width="100" Margin="5" Background="#DC3545" Foreground="White" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <DataGrid x:Name="RepairsGrid" Grid.Row="1" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionMode="Single" 
                  SelectionChanged="RepairsGrid_SelectionChanged" RowHeight="30"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding IdРемонта}" Width="50"/>
                <DataGridTextColumn Header="Авто" Binding="{Binding IdАвтоNavigation.ГосНомер}" Width="120" FontWeight="Bold"/>
                <DataGridTextColumn Header="Тип ремонта" Binding="{Binding ТипРемонта}" Width="180"/>
                <DataGridTextColumn Header="План. Пробег" Binding="{Binding ПлановыйПробег}" Width="100"/>
                <DataGridTextColumn Header="План. Дата" Binding="{Binding ПлановаяДата, StringFormat=\{0:dd.MM.yyyy\}}" Width="100"/>
                <DataGridTextColumn Header="Факт. Дата" Binding="{Binding ФактическаяДата, StringFormat=\{0:dd.MM.yyyy\}}" Width="100"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Статус}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
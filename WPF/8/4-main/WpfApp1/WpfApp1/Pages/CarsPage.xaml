<Page x:Class="WpfApp1.CarsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Автопарк" Background="White">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Данные автомобиля" Margin="0,0,0,15" Padding="10">
            <StackPanel>
                <UniformGrid Columns="4" Margin="0,0,0,10">
                    <StackPanel Margin="5,0,5,10">
                        <TextBlock Text="Марка и Модель:"/>
                        <TextBox x:Name="TxtModel" Padding="3"/>
                    </StackPanel>

                    <StackPanel Margin="5,0,5,10">
                        <TextBlock Text="Гос. номер:"/>
                        <TextBox x:Name="TxtNumber" Padding="3"/>
                    </StackPanel>

                    <StackPanel Margin="5,0,5,10">
                        <TextBlock Text="Класс авто:"/>
                        <ComboBox x:Name="CmbClass" Padding="3"/>
                    </StackPanel>

                    <StackPanel Margin="5,0,5,10">
                        <TextBlock Text="Цена (сутки):"/>
                        <TextBox x:Name="TxtPrice" Padding="3"/>
                    </StackPanel>

                    <StackPanel Margin="5,0">
                        <TextBlock Text="Год выпуска:"/>
                        <TextBox x:Name="TxtYear" Padding="3"/>
                    </StackPanel>

                    <StackPanel Margin="5,0">
                        <TextBlock Text="Пробег (км):"/>
                        <TextBox x:Name="TxtMileage" Padding="3"/>
                    </StackPanel>

                    <StackPanel Margin="5,0">
                        <TextBlock Text="Статус:"/>
                        <ComboBox x:Name="CmbStatus" Padding="3"/>
                    </StackPanel>
                </UniformGrid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить" Click="SaveBtn_Click" Width="100" Margin="5" Background="#28A745" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
                    <Button Content="Очистить" Click="ClearBtn_Click" Width="100" Margin="5" Background="#6C757D" Foreground="White" Cursor="Hand"/>
                    <Button Content="Удалить" Click="DeleteBtn_Click" Width="100" Margin="5" Background="#DC3545" Foreground="White" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Поиск (модель, номер):" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
            <TextBox x:Name="SearchTextBox" Width="250" Padding="3" TextChanged="SearchTextBox_TextChanged" Margin="0,0,20,0"/>

            <TextBlock Text="Фильтр по статусу:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
            <ComboBox x:Name="FilterStatusCombo" Width="150" Padding="3" SelectionChanged="FilterStatusCombo_SelectionChanged"/>
        </StackPanel>

        <DataGrid x:Name="CarsGrid" Grid.Row="2" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionMode="Single" 
                  SelectionChanged="CarsGrid_SelectionChanged" RowHeight="30"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ID_Авто}" Width="40"/>
                <DataGridTextColumn Header="Марка/Модель" Binding="{Binding Марка_Модель}" Width="*"/>
                <DataGridTextColumn Header="Гос. Номер" Binding="{Binding Гос_Номер}" Width="120"/>
                <DataGridTextColumn Header="Класс" Binding="{Binding Класс}" Width="100"/>
                <DataGridTextColumn Header="Год" Binding="{Binding Год_Выпуска}" Width="70"/>
                <DataGridTextColumn Header="Пробег" Binding="{Binding Текущий_Пробег}" Width="90"/>
                <DataGridTextColumn Header="Цена/Сутки" Binding="{Binding Цена_Сутки, StringFormat={}{0:F2} ₽}" Width="110"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Статус}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
<Page x:Class="WpfApp1.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      Title="Статистика" Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Аналитика автопроката" FontSize="26" FontWeight="Bold" Margin="0,0,0,20" Foreground="#1E293B"/>

        <UniformGrid Grid.Row="1" Columns="2">
            <GroupBox Header="Состав автопарка (по классам)" Margin="10" Foreground="#475569" FontWeight="SemiBold">
                <lvc:PieChart x:Name="ChartClasses" LegendLocation="Bottom" Hoverable="True"/>
            </GroupBox>

            <GroupBox Header="Выручка по классам авто (₽)" Margin="10" Foreground="#475569" FontWeight="SemiBold">
                <lvc:CartesianChart x:Name="ChartRevenue">
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="Сумма" LabelFormatter="{Binding Formatter}"/>
                    </lvc:CartesianChart.AxisY>
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Title="Классы" Labels="{Binding ClassLabels}"/>
                    </lvc:CartesianChart.AxisX>
                </lvc:CartesianChart>
            </GroupBox>
        </UniformGrid>
    </Grid>
</Page>
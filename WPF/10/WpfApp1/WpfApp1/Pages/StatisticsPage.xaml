<Page x:Class="WpfApp1.Pages.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      Title="Статистика" Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Аналитика кредитного портфеля" FontSize="26" FontWeight="Bold" Margin="0,0,0,20"/>

        <UniformGrid Grid.Row="1" Columns="2">
            <GroupBox Header="Популярность кредитных продуктов" Margin="10">
                <lvc:PieChart x:Name="ChartProducts" LegendLocation="Bottom" Hoverable="True">
                </lvc:PieChart>
            </GroupBox>

            <GroupBox Header="Объемы выдачи (по продуктам)" Margin="10">
                <lvc:CartesianChart x:Name="ChartAmounts">
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="Сумма (₽)" LabelFormatter="{Binding Formatter}"></lvc:Axis>
                    </lvc:CartesianChart.AxisY>
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Title="Продукты" Labels="{Binding ProductLabels}"></lvc:Axis>
                    </lvc:CartesianChart.AxisX>
                </lvc:CartesianChart>
            </GroupBox>
        </UniformGrid>
    </Grid>
</Page>
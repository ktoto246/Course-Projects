<Page x:Class="WpfApp1.Pages.PaymentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Платежи" Background="White">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Данные платежа" Margin="0,0,0,15" Padding="10">
            <StackPanel>
                <UniformGrid Columns="4" Margin="0,0,0,10">
                    <StackPanel Margin="5,0">
                        <TextBlock Text="Займ:"/>
                        <ComboBox x:Name="CmbLoan" Padding="3"/>
                    </StackPanel>
                    <StackPanel Margin="5,0">
                        <TextBlock Text="Дата платежа:"/>
                        <DatePicker x:Name="DpPaymentDate"/>
                    </StackPanel>
                    <StackPanel Margin="5,0">
                        <TextBlock Text="Сумма платежа:"/>
                        <TextBox x:Name="TxtAmount" Padding="3"/>
                    </StackPanel>
                    <StackPanel Margin="5,0">
                        <TextBlock Text="Тип платежа:"/>
                        <ComboBox x:Name="CmbPaymentType" Padding="3"/>
                    </StackPanel>
                </UniformGrid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить" Click="SaveBtn_Click" Width="100" Margin="5" Background="#28A745" Foreground="White" FontWeight="Bold"/>
                    <Button Content="Новый" Click="ClearBtn_Click" Width="100" Margin="5" Background="#6C757D" Foreground="White"/>
                    <Button Content="Удалить" Click="DeleteBtn_Click" Width="100" Margin="5" Background="#DC3545" Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
            <TextBox x:Name="SearchTextBox" Width="300" Padding="3" TextChanged="SearchTextBox_TextChanged" Margin="0,0,20,0"/>
            <TextBlock Text="Фильтр по типу:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
            <ComboBox x:Name="FilterTypeCombo" Width="150" Padding="3" SelectionChanged="FilterTypeCombo_SelectionChanged"/>
        </StackPanel>

        <DataGrid x:Name="PaymentsGrid" Grid.Row="2" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionMode="Single" 
                  SelectionChanged="PaymentsGrid_SelectionChanged" RowHeight="30"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID Платежа" Binding="{Binding ID_Платежа}" Width="90"/>
                <DataGridTextColumn Header="ID Займа" Binding="{Binding ID_Займа}" Width="80"/>
                <DataGridTextColumn Header="ФИО клиента" Binding="{Binding Займ.Клиент.ФИО}" Width="*"/>
                <DataGridTextColumn Header="Дата платежа" Binding="{Binding Дата_Платежа, StringFormat=\{0:dd.MM.yyyy\}}" Width="110"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding Сумма_Платежа, StringFormat={}{0:F2}}" Width="100"/>
                <DataGridTextColumn Header="Тип платежа" Binding="{Binding Тип_Платежа}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>

<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учет займов - Коммерческий банк" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#2C3E50">
            <StackPanel Margin="10">
                <TextBlock Text="BANK" Foreground="White" FontSize="20" 
                           FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,30"/>

                <Button Content="Клиенты" Height="40" Margin="0,5" Padding="10,0"
                        Background="Transparent" Foreground="White" BorderThickness="0"
                        HorizontalContentAlignment="Left" Cursor="Hand" Click="NavClients_Click"/>

                <Button Content="Кредитные продукты" Height="40" Margin="0,5" Padding="10,0"
                        Background="Transparent" Foreground="White" BorderThickness="0"
                        HorizontalContentAlignment="Left" Cursor="Hand" Click="NavProducts_Click"/>

                <Button Content="Активные займы" Height="40" Margin="0,5" Padding="10,0"
                        Background="Transparent" Foreground="White" BorderThickness="0"
                        HorizontalContentAlignment="Left" Cursor="Hand" Click="NavLoans_Click"/>

                <Button Content="История платежей" Height="40" Margin="0,5" Padding="10,0"
                        Background="Transparent" Foreground="White" BorderThickness="0"
                        HorizontalContentAlignment="Left" Cursor="Hand" Click="NavPayments_Click"/>

                <Button Content="Статистика" Height="40" Margin="0,5" Padding="10,0"
                        Background="Transparent" Foreground="White" BorderThickness="0"
                        HorizontalContentAlignment="Left" Cursor="Hand" Click="NavStats_Click"/>

                <Separator Background="#34495E" Margin="0,20"/>

            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="#F5F6FA">
            <Frame Name="MainFrame" NavigationUIVisibility="Hidden" Margin="20"/>
        </Grid>
    </Grid>
</Window>
<Page x:Class="WpfApp1.Pages.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Продукция" Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="0,0,0,15" Margin="0,0,0,15">
            <Grid>
                <TextBlock Text="Список продукции" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="Рассчитать всё" Click="CalcBtn_Click" HorizontalAlignment="Right" Width="180" Background="#0078D7" Foreground="White" BorderThickness="0" Padding="8" Cursor="Hand" FontWeight="Bold"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold" Foreground="#6C757D"/>
                    <TextBox x:Name="ProductsSearchTextBox" Width="300" Padding="5" TextChanged="ProductsSearchTextBox_TextChanged"/>
                </StackPanel>

                <DataGrid x:Name="ProductsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="ProductsGrid_SelectionChanged" RowHeight="35">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding IdПродукта}" Width="50"/>
                        <DataGridTextColumn Header="Название" Binding="{Binding Название}" Width="*"/>
                        <DataGridTextColumn Header="Себестоимость" Binding="{Binding Себестоимость, StringFormat={}{0:N2}}" Width="130" FontWeight="Bold"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Border Grid.Column="1" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" Padding="20">
                <StackPanel>
                    <TextBlock Text="Карточка продукта" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                    <TextBlock Text="Название:" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtName" Padding="5" Margin="0,0,0,15"/>
                    <TextBlock Text="Накладные расходы:" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtOverhead" Padding="5" Margin="0,0,0,10"/>

                    <TextBlock Text="Итоговая себестоимость:" Margin="0,0,0,5" Foreground="#6C757D"/>
                    <TextBlock x:Name="TxtTotalCost" Text="0.00" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2D2D30"/>

                    <Button Content="Сохранить" Click="SaveBtn_Click" Background="#28A745" Foreground="White" BorderThickness="0" Padding="10" Margin="0,0,0,10" FontWeight="Bold"/>
                    <Button Content="Новый" Click="ClearBtn_Click" Background="#6C757D" Foreground="White" BorderThickness="0" Padding="10" Margin="0,0,0,10"/>
                    <Button Content="Удалить" Click="DeleteBtn_Click" Background="#DC3545" Foreground="White" BorderThickness="0" Padding="10"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>

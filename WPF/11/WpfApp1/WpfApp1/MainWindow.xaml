<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учет себестоимости предприятия" Height="700" Width="1200" 
        WindowStartupLocation="CenterScreen" Background="#F0F2F5">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3E3E42"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2D2D30">
            <StackPanel Margin="0,20,0,0">
                <TextBlock Text="НАВИГАЦИЯ" Foreground="#858585" FontSize="12" FontWeight="Bold" Margin="20,0,0,15"/>
                
                <Button x:Name="BtnProducts" Content="Продукция" Style="{StaticResource MenuButtonStyle}" Click="BtnProducts_Click"/>
                <Button x:Name="BtnMaterials" Content="Материалы" Style="{StaticResource MenuButtonStyle}" Click="BtnMaterials_Click"/>
                <Button x:Name="BtnLabor" Content="Трудозатраты" Style="{StaticResource MenuButtonStyle}" Click="BtnLabor_Click"/>
                <Button x:Name="BtnComposition" Content="Рецептура" Style="{StaticResource MenuButtonStyle}" Click="BtnComposition_Click"/>
                <Button x:Name="BtnDashboard" Content="Аналитика" Style="{StaticResource MenuButtonStyle}" Click="BtnDashboard_Click"/>
            </StackPanel>
        </Border>

        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Background="White"/>
        
    </Grid>
</Window>
<Page x:Class="WpfApp1.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      Title="Аналитика и графики" Background="#F0F2F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="0,0,0,15" Margin="0,0,0,15">
            <Grid>
                <TextBlock Text="Аналитика себестоимости" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <Button Content="Обновить данные" Click="RefreshBtn_Click" Width="150" HorizontalAlignment="Right" Background="#0078D7" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="5"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Сравнение стоимости товаров (руб)" FontWeight="SemiBold" FontSize="16" Foreground="#6C757D" Margin="0,0,0,10"/>

                <lvc:CartesianChart Grid.Row="1" Series="{Binding BarSeries}">
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Title="Продукция" Labels="{Binding BarLabels}">
                            <lvc:Axis.Separator>
                                <lvc:Separator Step="1"/>
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="Себестоимость" LabelFormatter="{Binding Formatter}"/>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="Структура затрат" FontWeight="SemiBold" FontSize="16" Foreground="#6C757D" Margin="0,0,0,15"/>
                    <TextBlock Text="Выберите товар:" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbProducts" DisplayMemberPath="Название" SelectedValuePath="IdПродукта" SelectionChanged="CmbProducts_SelectionChanged" Padding="5"/>
                </StackPanel>

                <lvc:PieChart Grid.Column="1" Series="{Binding PieSeries}" LegendLocation="Right" InnerRadius="40" Margin="10"/>
            </Grid>
        </Border>
    </Grid>
</Page>

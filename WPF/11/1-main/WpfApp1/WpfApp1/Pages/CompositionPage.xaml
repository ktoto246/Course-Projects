<Page x:Class="WpfApp1.Pages.CompositionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Рецептура" Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="0,0,0,15" Margin="0,0,0,15">
            <TextBlock Text="Рецептура продукции" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,10" VerticalAlignment="Center">
                <TextBlock Text="Фильтр по продукту:" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold"/>
                <ComboBox x:Name="CompositionProductFilterComboBox" Width="260" DisplayMemberPath="Название" SelectionChanged="CompositionProductFilterComboBox_SelectionChanged"/>
            </StackPanel>

            <DataGrid x:Name="CompositionGrid" Grid.Row="1" Grid.Column="0" AutoGenerateColumns="False" 
                      IsReadOnly="True" SelectionMode="Single" SelectionChanged="CompositionGrid_SelectionChanged"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E0E0E0"
                      BorderThickness="1" BorderBrush="#D1D1D1" RowHeight="35" Margin="0,0,20,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Продукт" Binding="{Binding IdПродуктаNavigation.Название}" Width="150"/>
                    <DataGridTextColumn Header="Материал" Binding="{Binding IdМатериалаNavigation.Название}" Width="150"/>
                    <DataGridTextColumn Header="Кол-во" Binding="{Binding Количество}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="1" Grid.Column="1" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" Padding="20">
                <StackPanel>
                    <TextBlock Text="Состав продукта" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                    <TextBlock Text="Готовый продукт:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbProduct" DisplayMemberPath="Название" SelectedValuePath="IdПродукта" Padding="5" Margin="0,0,0,15" FontSize="14"/>

                    <TextBlock Text="Сырье (Материал):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbMaterial" DisplayMemberPath="Название" SelectedValuePath="IdМатериала" Padding="5" Margin="0,0,0,15" FontSize="14"/>

                    <TextBlock Text="Норма расхода (кол-во):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtQuantity" Padding="5" Margin="0,0,0,25" FontSize="14"/>

                    <Button Content="Сохранить" Click="SaveBtn_Click" Background="#28A745" Foreground="White" BorderThickness="0" Padding="10" Margin="0,0,0,10" Cursor="Hand" FontWeight="Bold"/>
                    <Button Content="Очистить (Новая запись)" Click="ClearBtn_Click" Background="#6C757D" Foreground="White" BorderThickness="0" Padding="10" Margin="0,0,0,10" Cursor="Hand"/>
                    <Button Content="Удалить из рецепта" Click="DeleteBtn_Click" Background="#DC3545" Foreground="White" BorderThickness="0" Padding="10" Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>

<Page x:Class="WpfApp1.StatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      Title="Статистика" Background="#FFFFFF"
      Loaded="Page_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Общая сводка" FontSize="24" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,20"/>

        <WrapPanel Grid.Row="1" Orientation="Horizontal">
            <Border Width="250" Height="120" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="8" Margin="0,0,20,20" Padding="20">
                <StackPanel>
                    <TextBlock Text="Всего студентов" FontSize="16" Foreground="#4B5563"/>
                    <TextBlock x:Name="TxtTotalStudents" Text="0" FontSize="36" FontWeight="Bold" Foreground="#1D4ED8" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Width="250" Height="120" Background="#ECFCCB" BorderBrush="#D9F99D" BorderThickness="1" CornerRadius="8" Margin="0,0,20,20" Padding="20">
                <StackPanel>
                    <TextBlock Text="Всего преподавателей" FontSize="16" Foreground="#4B5563"/>
                    <TextBlock x:Name="TxtTotalTeachers" Text="0" FontSize="36" FontWeight="Bold" Foreground="#4D7C0F" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Width="250" Height="120" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="8" Margin="0,0,20,20" Padding="20">
                <StackPanel>
                    <TextBlock Text="Средний балл" FontSize="16" Foreground="#4B5563"/>
                    <TextBlock x:Name="TxtAverageGrade" Text="0.0" FontSize="36" FontWeight="Bold" Foreground="#B91C1C" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <Border Grid.Row="2" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Количество студентов по группам" FontSize="18" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,15"/>

                <lvc:CartesianChart x:Name="StudentsChart" Grid.Row="1" LegendLocation="None">
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis x:Name="AxisX" Title="Группы">
                            <lvc:Axis.Separator>
                                <lvc:Separator Step="1"/>
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="Человек" MinValue="0"/>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </Grid>
        </Border>
    </Grid>
</Page>
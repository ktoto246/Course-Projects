<Page x:Class="WpfApp1.GroupsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Группы" Background="#FFFFFF"
      Loaded="Page_Loaded">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <DataGrid x:Name="GroupsGrid" Grid.Column="0" Margin="0,0,15,0"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionChanged="GroupsGrid_SelectionChanged"
                  Background="#FFFFFF" BorderBrush="#E0E0E0" RowHeight="35" HeadersVisibility="Column">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding GroupId}" Width="40"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="100"/>
                <DataGridTextColumn Header="Специальность" Binding="{Binding Specialty}" Width="*"/>
                <DataGridTextColumn Header="Код" Binding="{Binding SpecialtyCode}" Width="80"/>
                <DataGridTextColumn Header="Курс" Binding="{Binding Course}" Width="60"/>
                <DataGridTextColumn Header="Куратор" Binding="{Binding Curator.LastName}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Column="1" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="15">
            <StackPanel>
                <TextBlock Text="Управление группами" FontSize="18" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,15"/>

                <TextBlock Text="Название *" Foreground="#555555" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtName" Height="30" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Специальность *" Foreground="#555555" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtSpecialty" Height="30" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Код специальности *" Foreground="#555555" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtSpecialtyCode" Height="30" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Курс *" Foreground="#555555" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtCourse" Height="30" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Куратор" Foreground="#555555" Margin="0,0,0,2"/>
                <ComboBox x:Name="CmbCurator" Height="30" Margin="0,0,0,20" DisplayMemberPath="LastName" SelectedValuePath="TeacherId"/>

                <Button Content="Добавить" Height="35" Margin="0,0,0,10" Background="#10B981" Foreground="White" FontWeight="Bold" Click="BtnAdd_Click"/>
                <Button Content="Сохранить изменения" Height="35" Margin="0,0,0,10" Background="#3B82F6" Foreground="White" FontWeight="Bold" Click="BtnEdit_Click"/>
                <Button Content="Удалить" Height="35" Margin="0,0,0,15" Background="#EF4444" Foreground="White" FontWeight="Bold" Click="BtnDelete_Click"/>

                <Button Content="Очистить форму" Height="30" Background="#E5E7EB" Foreground="#374151" Click="BtnClear_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
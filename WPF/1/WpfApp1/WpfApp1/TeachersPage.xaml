<Page x:Class="WpfApp1.TeachersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Преподаватели" Background="#FFFFFF"
      Loaded="Page_Loaded">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <DataGrid x:Name="TeachersGrid" Grid.Column="0" Margin="0,0,15,0"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionChanged="TeachersGrid_SelectionChanged"
                  Background="#FFFFFF" BorderBrush="#E0E0E0" RowHeight="35" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding TeacherId}" Width="40"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="*"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="*"/>
                <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="*"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Column="1" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="15">
            <StackPanel>
                <TextBlock Text="Управление данными" FontSize="18" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,15"/>

                <TextBlock Text="Фамилия *" Foreground="#555555" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtLastName" Height="30" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Имя *" Foreground="#555555" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtFirstName" Height="30" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Отчество" Foreground="#555555" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtMiddleName" Height="30" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Телефон" Foreground="#555555" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtPhone" Height="30" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Email" Foreground="#555555" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtEmail" Height="30" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Должность *" Foreground="#555555" Margin="0,0,0,2"/>
                <TextBox x:Name="TxtPosition" Height="30" Margin="0,0,0,20" Padding="5"/>

                <Button Content="Добавить" Height="35" Margin="0,0,0,10" Background="#10B981" Foreground="White" FontWeight="Bold" Click="BtnAdd_Click"/>
                <Button Content="Сохранить изменения" Height="35" Margin="0,0,0,10" Background="#3B82F6" Foreground="White" FontWeight="Bold" Click="BtnEdit_Click"/>
                <Button Content="Удалить" Height="35" Margin="0,0,0,15" Background="#EF4444" Foreground="White" FontWeight="Bold" Click="BtnDelete_Click"/>

                <Button Content="Очистить форму" Height="30" Background="#E5E7EB" Foreground="#374151" Click="BtnClear_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
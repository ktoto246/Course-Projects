<Page x:Class="WpfApp1.JournalPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Журнал" Background="#FFFFFF"
      Loaded="Page_Loaded">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <DataGrid x:Name="JournalGrid" Grid.Column="0" Margin="0,0,15,0"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionChanged="JournalGrid_SelectionChanged"
                  Background="#FFFFFF" BorderBrush="#E0E0E0" RowHeight="35" HeadersVisibility="Column">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding RecordId}" Width="40"/>
                <DataGridTextColumn Header="Студент" Binding="{Binding Student.LastName}" Width="100"/>
                <DataGridTextColumn Header="Предмет" Binding="{Binding Schedule.Subject.Name}" Width="*"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding Schedule.ClassDate, StringFormat=dd.MM.yyyy}" Width="80"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Оценка" Binding="{Binding Grade}" Width="60"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding ControlType}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Column="1" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Учет успеваемости" FontSize="18" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,15"/>

                    <TextBlock Text="Студент *" Foreground="#555555" Margin="0,0,0,2"/>
                    <ComboBox x:Name="CmbStudent" Height="30" Margin="0,0,0,10" DisplayMemberPath="FullName" SelectedValuePath="StudentId"/>

                    <TextBlock Text="Занятие *" Foreground="#555555" Margin="0,0,0,2"/>
                    <ComboBox x:Name="CmbSchedule" Height="30" Margin="0,0,0,10" DisplayMemberPath="Info" SelectedValuePath="ScheduleId"/>

                    <TextBlock Text="Статус *" Foreground="#555555" Margin="0,0,0,2"/>
                    <ComboBox x:Name="CmbStatus" Height="30" Margin="0,0,0,10">
                        <ComboBoxItem Content="присутствовал"/>
                        <ComboBoxItem Content="отсутствовал"/>
                        <ComboBoxItem Content="опоздал"/>
                    </ComboBox>

                    <TextBlock Text="Оценка" Foreground="#555555" Margin="0,0,0,2"/>
                    <TextBox x:Name="TxtGrade" Height="30" Margin="0,0,0,10" Padding="5"/>

                    <TextBlock Text="Тип контроля *" Foreground="#555555" Margin="0,0,0,2"/>
                    <ComboBox x:Name="CmbControlType" Height="30" Margin="0,0,0,10">
                        <ComboBoxItem Content="текущий"/>
                        <ComboBoxItem Content="практика"/>
                        <ComboBoxItem Content="экзамен"/>
                    </ComboBox>

                    <TextBlock Text="Дата внесения *" Foreground="#555555" Margin="0,0,0,2"/>
                    <DatePicker x:Name="DpEntryDate" Height="30" Margin="0,0,0,20"/>

                    <Button Content="Добавить" Height="35" Margin="0,0,0,10" Background="#10B981" Foreground="White" FontWeight="Bold" Click="BtnAdd_Click"/>
                    <Button Content="Сохранить изменения" Height="35" Margin="0,0,0,10" Background="#3B82F6" Foreground="White" FontWeight="Bold" Click="BtnEdit_Click"/>
                    <Button Content="Удалить" Height="35" Margin="0,0,0,15" Background="#EF4444" Foreground="White" FontWeight="Bold" Click="BtnDelete_Click"/>

                    <Button Content="Очистить форму" Height="30" Background="#E5E7EB" Foreground="#374151" Click="BtnClear_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
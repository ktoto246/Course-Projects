<Page x:Class="WpfApp1.Pages.WorkloadAnalyticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="Нагрузка сотрудников">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Топ сотрудников по количеству техники" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20">
            <lvc:CartesianChart Series="{Binding WorkloadSeries}" XAxes="{Binding XAxes}" />
        </Border>
    </Grid>
</Page>
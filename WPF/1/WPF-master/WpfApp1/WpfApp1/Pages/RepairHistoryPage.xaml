<Page x:Class="WpfApp1.Pages.RepairHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Журнал ремонтов">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Журнал ремонтов" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>


        <Border Grid.Row="1" Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderLight}" x:Name="AddPanel" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Добавить запись о ремонте" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"/>
                
                <WrapPanel Margin="0,0,0,15">
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Оборудование" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <ComboBox x:Name="cmbEquipment" Width="200" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Дата сдачи" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <DatePicker x:Name="dpDateIn" Width="130"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Дата возврата" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <DatePicker x:Name="dpDateOut" Width="130"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Стоимость" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtCost" Width="100"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Проблема" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtProblem" Width="250"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Подрядчик" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtContractor" Width="180"/>
                    </StackPanel>
                </WrapPanel>

                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="Добавить" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="BtnAdd_Click"/>
                    </StackPanel>
                </Grid>
                
                <Separator Margin="0,15,0,15" Background="{StaticResource BorderLight}"/>
                
                <Grid>
                    <WrapPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Поиск" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                            <TextBox x:Name="txtSearch" Width="250" TextChanged="Filter_Changed" ToolTip="Поиск по журналу ремонтов"/>
                        </StackPanel>
                    </WrapPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Button Content="Удалить" Style="{StaticResource DangerButton}" Margin="0,0,10,0" Click="BtnDelete_Click" Name="BtnDelete"/>
                        <Button Content="Экспорт в Excel" Style="{StaticResource SuccessButton}" Click="BtnExportExcel_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        
        <Border Grid.Row="2" Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="1">
            <DataGrid x:Name="RepairsGrid" AutoGenerateColumns="False" SelectionMode="Single" CanUserAddRows="False" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Оборудование" Binding="{Binding Equipment.Name}" Width="200"/>
                    <DataGridTextColumn Header="Проблема" Binding="{Binding IssueDescription}" Width="250"/>
                    <DataGridTextColumn Header="Сдали" Binding="{Binding DateIn, StringFormat=\{0:dd.MM.yyyy\}}" Width="100"/>
                    <DataGridTextColumn Header="Вернули" Binding="{Binding DateOut, StringFormat=\{0:dd.MM.yyyy\}}" Width="100"/>
                    <DataGridTextColumn Header="Стоимость" Binding="{Binding Cost, StringFormat=\{0:N2\}}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>


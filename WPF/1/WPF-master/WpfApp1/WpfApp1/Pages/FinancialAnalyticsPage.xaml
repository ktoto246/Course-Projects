<Page x:Class="WpfApp1.Pages.FinancialAnalyticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="Стоимость фонда">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Суммарная стоимость фонда по категориям" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
        <TextBlock x:Name="txtNoData" Grid.Row="1" Text="Нет данных для расчета стоимости" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
        <Border x:Name="ChartBorder" Grid.Row="1" Background="White" CornerRadius="8" Padding="20">
            <lvc:CartesianChart Series="{Binding FinancialSeries}" XAxes="{Binding XAxes}" />
        </Border>
    </Grid>
</Page>
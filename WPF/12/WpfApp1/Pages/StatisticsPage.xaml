<Page x:Class="WpfApp1.Pages.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="Аналитика">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Статистика и аналитика" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <UniformGrid Grid.Row="1" Columns="2">
            <Border Background="{StaticResource CardBg}" Margin="10" CornerRadius="8" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Состав флота (по категориям)" FontWeight="SemiBold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <lvc:PieChart Grid.Row="1" x:Name="PieChartFleet" LegendPosition="Right"/>
                </Grid>
            </Border>

            <Border Background="{StaticResource CardBg}" Margin="10" CornerRadius="8" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Выручка по категориям (руб.)" FontWeight="SemiBold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <lvc:CartesianChart Grid.Row="1" x:Name="BarChartRevenue" LegendPosition="Bottom"/>
                </Grid>
            </Border>
        </UniformGrid>
    </Grid>
</Page>
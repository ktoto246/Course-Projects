<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учет проката плавсредств" Height="800" Width="1300" WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgLight}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource BgDark}">
            <StackPanel Margin="0,30,0,10">
                <TextBlock Text="Лодочная Станция" Foreground="White" FontWeight="Bold" FontSize="20" Margin="20,0,0,40"/>

                <TextBlock Text="ОСНОВНОЕ" Foreground="#64748B" FontSize="12" FontWeight="Bold" Margin="20,10,0,5"/>
                <Button x:Name="BtnWatercrafts" Content="Плавсредства" Style="{StaticResource NavButton}" Click="BtnWatercrafts_Click"/>
                <Button x:Name="BtnRentals" Content="Журнал проката" Style="{StaticResource NavButton}" Click="BtnRentals_Click"/>
                <Button x:Name="BtnDamages" Content="Поломки и штрафы" Style="{StaticResource NavButton}" Click="BtnDamages_Click"/>

                <TextBlock Text="БАЗА" Foreground="#64748B" FontSize="12" FontWeight="Bold" Margin="20,25,0,5"/>
                <Button x:Name="BtnClients" Content="Клиенты" Style="{StaticResource NavButton}" Click="BtnClients_Click"/>
                <Button x:Name="BtnEmployees" Content="Сотрудники" Style="{StaticResource NavButton}" Click="BtnEmployees_Click"/>
                <Button x:Name="BtnCategories" Content="Категории" Style="{StaticResource NavButton}" Click="BtnCategories_Click"/>

                <TextBlock Text="ОТЧЕТЫ" Foreground="#64748B" FontSize="12" FontWeight="Bold" Margin="20,10,0,5"/>

                <Button x:Name="BtnStatistics" Content="Статистика" Style="{StaticResource NavButton}" Click="BtnStatistics_Click"/>
            </StackPanel>
        </Grid>

        <Border Grid.Column="1" Background="{StaticResource BgLight}">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Margin="0"/>
        </Border>
    </Grid>
</Window>
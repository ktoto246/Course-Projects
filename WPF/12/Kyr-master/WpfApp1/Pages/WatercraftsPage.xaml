<Page x:Class="WpfApp1.Pages.WatercraftsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Справочник плавсредств">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Плавсредства" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Добавление нового плавсредства" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"/>

                <WrapPanel Margin="0,0,0,15" VerticalAlignment="Bottom">
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Категория" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <ComboBox x:Name="cmbCategory" Width="150" DisplayMemberPath="Название" SelectedValuePath="IdКатегории"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Модель" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtModel" Width="200"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Серийный номер" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtSerial" Width="150"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Состояние" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <ComboBox x:Name="cmbStatus" Width="120">
                            <ComboBoxItem Content="Исправно" IsSelected="True"/>
                            <ComboBoxItem Content="В ремонте"/>
                            <ComboBoxItem Content="Списано"/>
                        </ComboBox>
                    </StackPanel>

                    <Button Content="Добавить" Style="{StaticResource PrimaryButton}" Margin="0,0,0,10" VerticalAlignment="Bottom" Height="34" Click="BtnAdd_Click"/>
                </WrapPanel>

                <Separator Margin="0,10,0,15" Background="{StaticResource BorderLight}"/>

                <Grid>
                    <WrapPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Поиск (по модели или серийнику)" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                            <TextBox x:Name="txtSearch" Width="250" TextChanged="Filter_Changed"/>
                        </StackPanel>
                    </WrapPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Button Content="Удалить" Style="{StaticResource DangerButton}" Margin="0,0,10,0" Click="BtnDelete_Click"/>
                        <Button Content="Сменить статус" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="BtnToggleStatus_Click"/>
                        <Button Content="Сохранить" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="BtnSave_Click"/>
                        <Button Content="Экспорт в Excel" Style="{StaticResource SuccessButton}" Click="BtnExportExcel_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="1">
            <DataGrid x:Name="WatercraftsGrid" AutoGenerateColumns="False" SelectionMode="Single" CanUserAddRows="False" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdПлавсредства}" IsReadOnly="True" Width="60"/>
                    <DataGridTextColumn Header="Категория" Binding="{Binding IdКатегорииNavigation.Название}" IsReadOnly="True" Width="120"/>
                    <DataGridTextColumn Header="Модель" Binding="{Binding Модель}" Width="*"/>
                    <DataGridTextColumn Header="Серийный номер" Binding="{Binding СерийныйНомер}" Width="150"/>
                    <DataGridTextColumn Header="Состояние" Binding="{Binding Состояние}" IsReadOnly="True" Width="120"/>
                    <DataGridCheckBoxColumn Header="Доступно" Binding="{Binding Доступно}" IsReadOnly="True" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
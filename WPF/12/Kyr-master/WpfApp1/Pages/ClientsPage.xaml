<Page x:Class="WpfApp1.Pages.ClientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Справочник клиентов">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="База клиентов" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Добавление нового клиента" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"/>

                <WrapPanel Margin="0,0,0,15" VerticalAlignment="Bottom">
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="ФИО" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtFio" Width="250"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Телефон" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtPhone" Width="150"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Паспортные данные" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtPassport" Width="200"/>
                    </StackPanel>

                    <Button Content="Добавить" Style="{StaticResource PrimaryButton}" Margin="0,0,0,10" VerticalAlignment="Bottom" Height="34" Click="BtnAdd_Click"/>
                </WrapPanel>

                <Separator Margin="0,10,0,15" Background="{StaticResource BorderLight}"/>

                <Grid>
                    <WrapPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Поиск (ФИО, телефон или паспорт)" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                            <TextBox x:Name="txtSearch" Width="300" TextChanged="Filter_Changed"/>
                        </StackPanel>
                    </WrapPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Button Content="Удалить" Style="{StaticResource DangerButton}" Margin="0,0,10,0" Click="BtnDelete_Click"/>
                        <Button Content="Сохранить изменения" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="BtnSave_Click"/>
                        <Button Content="Экспорт в Excel" Style="{StaticResource SuccessButton}" Click="BtnExportExcel_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="1">
            <DataGrid x:Name="ClientsGrid" AutoGenerateColumns="False" SelectionMode="Single" CanUserAddRows="False" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdКлиента}" IsReadOnly="True" Width="60"/>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding Фио}" Width="*"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Телефон}" Width="150"/>
                    <DataGridTextColumn Header="Паспорт" Binding="{Binding Паспорт}" Width="200"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
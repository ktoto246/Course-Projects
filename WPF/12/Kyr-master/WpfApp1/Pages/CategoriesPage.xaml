<Page x:Class="WpfApp1.Pages.CategoriesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Справочник категорий">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Настройка цен и категорий" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Добавить категорию" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"/>

                <WrapPanel Margin="0,0,0,15" VerticalAlignment="Bottom">
                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Название (например, Катер)" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtName" Width="250"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,10">
                        <TextBlock Text="Цена за час (руб.)" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox x:Name="txtPrice" Width="120"/>
                    </StackPanel>

                    <Button Content="Добавить" Style="{StaticResource PrimaryButton}" Margin="0,0,0,10" VerticalAlignment="Bottom" Height="34" Click="BtnAdd_Click"/>
                </WrapPanel>

                <Separator Margin="0,10,0,15" Background="{StaticResource BorderLight}"/>

                <Grid>
                    <WrapPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="Поиск по названию" Margin="0,0,0,5" Foreground="{StaticResource TextSecondary}"/>
                            <TextBox x:Name="txtSearch" Width="250" TextChanged="Filter_Changed"/>
                        </StackPanel>
                    </WrapPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Button Content="Удалить" Style="{StaticResource DangerButton}" Margin="0,0,10,0" Click="BtnDelete_Click"/>
                        <Button Content="Сохранить" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="BtnSave_Click"/>
                        <Button Content="Экспорт" Style="{StaticResource SuccessButton}" Click="BtnExportExcel_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource CardBg}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="1">
            <DataGrid x:Name="CategoriesGrid" AutoGenerateColumns="False" SelectionMode="Single" CanUserAddRows="False" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdКатегории}" IsReadOnly="True" Width="60"/>
                    <DataGridTextColumn Header="Наименование" Binding="{Binding Название}" Width="*"/>
                    <DataGridTextColumn Header="Цена за час" Binding="{Binding ЦенаЗаЧас}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
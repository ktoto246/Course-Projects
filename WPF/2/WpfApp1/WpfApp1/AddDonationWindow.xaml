<Window x:Class="WpfApp1.AddDonationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Добавление новой донации" 
        Height="500" Width="500"
        Icon="/Resources/Icon.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Background="#E2D9D9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#8A4442" Padding="15">
            <TextBlock Text="Новая донация" 
                       Foreground="#D9D9D9" 
                       FontSize="20" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </Border>
        <Border Grid.Row="1" Background="White" Margin="20" CornerRadius="5" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Идентификационный номер донора*"/>
                    <TextBox x:Name="txtDonorID"/>
                    <TextBlock Text="Компонент крови*"/>
                    <ComboBox x:Name="cbComponent">
                        <ComboBoxItem Content="Эритроциты" IsSelected="True"/>
                        <ComboBoxItem Content="Плазма"/>
                    </ComboBox>
                    <TextBlock Text="Группа крови*"/>
                    <ComboBox x:Name="cbBloodGroup">
                        <ComboBoxItem Content="O(I)"/>
                        <ComboBoxItem Content="A(II)"/>
                        <ComboBoxItem Content="B(III)"/>
                        <ComboBoxItem Content="AB(IV)"/>
                    </ComboBox>
                    <CheckBox x:Name="cbRh" Content="Резус-фактор положительный (Rh+)"/>
                    <TextBlock Text="Дата сбора*"/>
                    <DatePicker x:Name="dpDateSbora"/>
                    <TextBlock Text="Дата консервации"/>
                    <DatePicker x:Name="dpDateFreeze"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
        <Border Grid.Row="2" Background="White" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnCancel" Content="Отмена" 
                        Background="#8C8C8C" Foreground="White"
                        Click="BtnCancel_Click" Width="100"/>
                <Button x:Name="btnSave" Content="Сохранить" 
                        Background="#8A4442" Foreground="White"
                        Click="BtnSave_Click" Width="100"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

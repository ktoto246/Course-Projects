<Window x:Class="WpfApp1.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
       Title="Поиск совместимых компонентов" 
        Height="600" Width="1032"
        Icon="/Resources/Icon.ico"
        WindowStartupLocation="CenterOwner">
    <Grid Background="#E2D9D9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#8A4442" Padding="15">
            <TextBlock Text="Поиск совместимых компонентов крови" 
                       Foreground="#D9D9D9" 
                       FontSize="20" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </Border>
        <Border Grid.Row="1" Background="White" Margin="10" CornerRadius="5" Padding="15">
            <StackPanel>
                <TextBlock Text="Параметры реципиента:" 
                           FontWeight="Bold" 
                           Foreground="#8A4442"
                           FontSize="16" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="Искать компонент:" VerticalAlignment="Center"/>
                        <ComboBox x:Name="cbSearchComponent" Width="150" 
                                  SelectionChanged="CbSearchComponent_SelectionChanged">
                            <ComboBoxItem Content="Эритроциты" IsSelected="True"/>
                            <ComboBoxItem Content="Плазма"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0">
                        <TextBlock Text="Группа крови реципиента:" VerticalAlignment="Center"/>
                        <ComboBox x:Name="cbRecipientGroup" Width="100">
                            <ComboBoxItem Content="O(I)"/>
                            <ComboBoxItem Content="A(II)"/>
                            <ComboBoxItem Content="B(III)"/>
                            <ComboBoxItem Content="AB(IV)"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="20,0,0,0">
                        <TextBlock x:Name="tbRhLabel" Text="Резус-фактор реципиента:" 
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="cbRecipientRh" Width="80" Margin="5,0,0,0">
                            <ComboBoxItem Content="Rh+"/>
                            <ComboBoxItem Content="Rh-"/>
                        </ComboBox>
                    </StackPanel>
                    <Button Grid.Column="3" x:Name="btnSearch" Content="Найти совместимые" 
                            Click="BtnSearch_Click" Width="180" Height="22" VerticalAlignment="Top"/>
                </Grid>
                <Border BorderBrush="#8A4442" BorderThickness="1" 
                        CornerRadius="5" Padding="10" Margin="0,15,0,0">
                    <StackPanel>
                        <TextBlock Text="Информация о совместимости:" 
                                   FontWeight="Bold" 
                                   Foreground="#8A4442"/>
                        <TextBlock x:Name="tbCompatibilityInfo" 
                                   Text="Выберите параметры реципиента"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
        <Border Grid.Row="2" Background="White" Margin="10" CornerRadius="5" Padding="10">
            <StackPanel>
                <TextBlock Text="Результаты поиска:" 
                           FontWeight="Bold" 
                           Foreground="#8A4442"
                           FontSize="16" Margin="0,0,0,10"/>

                <DataGrid x:Name="dgResults" 
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          RowHeight="35"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID донора" 
                                            Binding="{Binding DonorID}" 
                                            Width="100"/>
                        <DataGridTextColumn Header="Компонент" 
                                            Binding="{Binding Component}" 
                                            Width="100"/>
                        <DataGridTextColumn Header="Группа крови" 
                                            Binding="{Binding BloodGroup}" 
                                            Width="120"/>
                        <DataGridTextColumn Header="Резус-фактор" 
                                            Binding="{Binding RhString}" 
                                            Width="100"/>
                        <DataGridTextColumn Header="Дата сбора" 
                                            Binding="{Binding Date_Sbora, StringFormat=dd.MM.yyyy}" 
                                            Width="100"/>
                        <DataGridTextColumn Header="Статус" 
                                            Binding="{Binding Status}" 
                                            Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock x:Name="tbResultsInfo" 
                           Margin="0,10,0,0"
                           FontStyle="Italic"
                           Text="Выполните поиск для отображения результатов"/>
            </StackPanel>
        </Border>
        <StatusBar Grid.Row="3" Background="#8A4442">
            <StatusBarItem>
                <TextBlock x:Name="tbStatus" Foreground="#D9D9D9" 
                           Text="Готово" Margin="10,0"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="tbResultsCount" Foreground="#D9D9D9" 
                           Text="Найдено: 0" Margin="10,0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>

<Window x:Class="WpfApp1.EditStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Изменение статуса" 
        Height="450" Width="500"
        Icon="/Resources/Icon.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="#F5F5F5"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>
    <Grid Background="#E2D9D9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#8A4442" Padding="15">
            <TextBlock Text="Изменение статуса компонента" 
                       Foreground="#D9D9D9" 
                       FontSize="20" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
        </Border>
        <Border Grid.Row="1" Background="White" Margin="20" CornerRadius="5" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="ID донора:"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtDonorID"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Компонент:"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtComponent"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Группа крови:"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtBloodGroup"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Резус-фактор:"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtRh"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Дата сбора:"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtDateSbora"/>
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Дата консервации:"/>
                <TextBox Grid.Row="5" Grid.Column="1" x:Name="txtDateFreeze"/>
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Текущий статус:" 
                           FontWeight="Bold"/>
                <TextBox Grid.Row="6" Grid.Column="1" x:Name="txtCurrentStatus" 
                         FontWeight="Bold" Foreground="#8A4442"/>
                <TextBlock Grid.Row="7" Grid.Column="0" Text="Новый статус:" 
                           FontWeight="Bold" Margin="0,10,0,0"/>
                <ComboBox Grid.Row="7" Grid.Column="1" x:Name="cbNewStatus" 
                          Margin="0,10,0,0"/>
                <Border Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" 
                        BorderBrush="#8A4442" BorderThickness="1" 
                        CornerRadius="5" Padding="10" Margin="0,15,0,0">
                    <StackPanel>
                        <TextBlock Text="Правила изменения статуса:" 
                                   FontWeight="Bold" Foreground="#8A4442"/>
                        <TextBlock x:Name="tbRules" TextWrapping="Wrap"/>
                        <TextBlock x:Name="tbWarning" Foreground="#DD1A1A" 
                                   FontWeight="Bold" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        <Border Grid.Row="2" Background="White" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnDelete" Content="Удалить" 
                        Background="#8C8C8C" Foreground="White"
                        Click="BtnDelete_Click" Width="100"
                        ToolTip="Удалить запись (только для статусов 'Выдана' и 'Бракованная')"/>
                <Button x:Name="btnCancel" Content="Отмена" 
                        Background="#8C8C8C" Foreground="White"
                        Click="BtnCancel_Click" Width="100" Margin="10,0,0,0"/>
                <Button x:Name="btnSave" Content="Сохранить" 
                        Background="#8A4442" Foreground="White"
                        Click="BtnSave_Click" Width="100" Margin="10,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

<Page x:Class="WpfApp1.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf" 
      Title="Аналитика" Background="#F0F2F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Аналитика парка СВТ" FontSize="24" FontWeight="Bold" HorizontalAlignment="Left"/>
            <Button Content="Обновить" Click="RefreshBtn_Click" HorizontalAlignment="Right" Width="100" Background="#0078D7" Foreground="White" BorderThickness="0" Padding="5"/>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
            <lvc:CartesianChart Series="{Binding TechCountSeries}">
                <lvc:CartesianChart.AxisX>
                    <lvc:Axis Title="Типы оборудования" Labels="{Binding TypeLabels}"/>
                </lvc:CartesianChart.AxisX>
            </lvc:CartesianChart>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15">
            <lvc:PieChart Series="{Binding StatusSeries}" LegendLocation="Right" InnerRadius="40"/>
        </Border>
    </Grid>
</Page>
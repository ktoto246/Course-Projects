<Page x:Class="WpfApp1.TechPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
     Title="Учет техники" Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="0,0,0,15" Margin="0,0,0,15">
            <TextBlock Text="Учет средств вычислительной техники" FontSize="24" FontWeight="Bold"/>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                    <TextBox x:Name="SearchBox" Width="200" TextChanged="FilterChanged"/>

                    <TextBlock Text="Тип:" VerticalAlignment="Center" Margin="20,0,5,0" FontWeight="SemiBold"/>
                    <ComboBox x:Name="TypeFilterCombo" Width="150" DisplayMemberPath="Название" SelectionChanged="FilterChanged"/>
                </StackPanel>

                <DataGrid x:Name="TechGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                          SelectionChanged="TechGrid_SelectionChanged" SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Инв. №" Binding="{Binding Инвентарный_номер}" Width="100"/>
                        <DataGridTextColumn Header="Тип" Binding="{Binding ТипСвт.Название}" Width="120"/>
                        <DataGridTextColumn Header="Модель" Binding="{Binding Модель}" Width="*"/>
                        <DataGridTextColumn Header="Сотрудник" Binding="{Binding Сотрудник.ФИО}" Width="150"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Статус}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Border Grid.Column="1" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" Padding="20">
                <StackPanel>
                    <TextBlock Text="Карточка техники" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                    <TextBlock Text="Инв. номер:"/>
                    <TextBox x:Name="TxtInv" Margin="0,5,0,15"/>

                    <TextBlock Text="Модель:"/>
                    <TextBox x:Name="TxtModel" Margin="0,5,0,15"/>

                    <TextBlock Text="Тип СВТ:"/>
                    <ComboBox x:Name="CmbType" DisplayMemberPath="Название" SelectedValuePath="IDТипа" Margin="0,5,0,15"/>

                    <TextBlock Text="Сотрудник:"/>
                    <ComboBox x:Name="CmbStaff" DisplayMemberPath="ФИО" SelectedValuePath="IDСотрудника" Margin="0,5,0,15"/>

                    <TextBlock Text="Статус:"/>
                    <ComboBox x:Name="CmbStatus" Margin="0,5,0,25">
                        <ComboBoxItem Content="В работе"/>
                        <ComboBoxItem Content="В ремонте"/>
                        <ComboBoxItem Content="На складе"/>
                        <ComboBoxItem Content="Списано"/>
                    </ComboBox>

                    <Button Content="Сохранить" Click="SaveBtn_Click" Background="#28A745" Foreground="White" Margin="0,0,0,10"/>
                    <Button Content="Очистить" Click="ClearBtn_Click" Background="#6C757D" Foreground="White" Margin="0,0,0,10"/>
                    <Button Content="Удалить" Click="DeleteBtn_Click" Background="#DC3545" Foreground="White"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
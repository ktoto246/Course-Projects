<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учет инвентаря - ГАУ СО Балашовский дом-интернат" Height="750" Width="1200" WindowStartupLocation="CenterScreen" Background="#f1f2f6">
    <Window.Resources>
        <Style TargetType="Button" x:Key="TopMenuButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#d2dae2"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#485460"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1e272e">
            <DockPanel LastChildFill="False" Margin="20,0">
                <TextBlock DockPanel.Dock="Left" Text="УЧЕТ ИНВЕНТАРЯ" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,30,0"/>

                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="Сотрудники" Style="{StaticResource TopMenuButton}" Click="BtnEmployees_Click"/>
                    <Button Content="Категории" Style="{StaticResource TopMenuButton}" Click="BtnCategories_Click"/>
                    <Button Content="Проживающие" Style="{StaticResource TopMenuButton}" Click="BtnResidents_Click"/>
                    <Button Content="Инвентарь" Style="{StaticResource TopMenuButton}" Click="BtnItems_Click"/>
                    <Button Content="Журнал выдачи" Style="{StaticResource TopMenuButton}" Click="BtnIssuanceLog_Click"/>
                </StackPanel>

                <Button DockPanel.Dock="Right" Content="Аналитика" Style="{StaticResource TopMenuButton}" Click="BtnAnalytics_Click" Background="#0fbcf9" Foreground="Black" FontWeight="Bold"/>
            </DockPanel>
        </Border>

        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
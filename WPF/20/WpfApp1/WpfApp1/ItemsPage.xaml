<Page x:Class="WpfApp1.ItemsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Инвентарь" Background="White">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtSearch" Width="250" Margin="0,0,20,0" Padding="2" TextChanged="TxtSearch_TextChanged"/>

            <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
            <ComboBox x:Name="CmbSort" Width="180" SelectionChanged="CmbSort_SelectionChanged">
                <ComboBoxItem Content="По умолчанию" IsSelected="True"/>
                <ComboBoxItem Content="Название (А-Я)"/>
                <ComboBoxItem Content="Название (Я-А)"/>
                <ComboBoxItem Content="По категории"/>
                <ComboBoxItem Content="Сначала меньше остаток"/>
            </ComboBox>
        </StackPanel>

        <DataGrid x:Name="GridItems" Grid.Row="1" Grid.Column="0" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="GridItems_SelectionChanged" Margin="0,0,15,0" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="40"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding ItemName}" Width="*"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Category.CategoryName}" Width="*"/>
                <DataGridTextColumn Header="Всего" Binding="{Binding TotalQuantity}" Width="60"/>
                <DataGridTextColumn Header="Доступно" Binding="{Binding AvailableQuantity}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="1" Grid.Column="1" Background="#f1f2f6" CornerRadius="5" Padding="15">
            <StackPanel>
                <TextBlock Text="УПРАВЛЕНИЕ ЗАПИСЬЮ" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <TextBlock Text="Наименование инвентаря:"/>
                <TextBox x:Name="TxtItemName" Margin="0,5,0,10" Padding="3"/>

                <TextBlock Text="Категория:"/>
                <ComboBox x:Name="CmbCategory" Margin="0,5,0,10" DisplayMemberPath="CategoryName" SelectedValuePath="ID"/>

                <TextBlock Text="Общее количество:"/>
                <TextBox x:Name="TxtTotalQty" Margin="0,5,0,10" Padding="3"/>

                <TextBlock Text="Доступно на складе:"/>
                <TextBox x:Name="TxtAvailableQty" Margin="0,5,0,20" Padding="3"/>

                <Button x:Name="BtnAdd" Content="Добавить запись" Height="35" Margin="0,0,0,10" Background="#2ecc71" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnAdd_Click"/>
                <Button x:Name="BtnUpdate" Content="Сохранить изменения" Height="35" Margin="0,0,0,10" Background="#3498db" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnUpdate_Click"/>
                <Button x:Name="BtnDelete" Content="Удалить выбранное" Height="35" Margin="0,0,0,20" Background="#e74c3c" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnDelete_Click"/>

                <Separator Margin="0,0,0,20"/>

                <Button x:Name="BtnClear" Content="Очистить поля" Height="30" Background="#95a5a6" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnClear_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
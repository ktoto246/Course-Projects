<Page x:Class="WpfApp1.IssuanceLogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Журнал выдачи" Background="White">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtSearch" Width="250" Margin="0,0,20,0" Padding="2" TextChanged="TxtSearch_TextChanged"/>

            <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
            <ComboBox x:Name="CmbSort" Width="180" SelectionChanged="CmbSort_SelectionChanged">
                <ComboBoxItem Content="По умолчанию" IsSelected="True"/>
                <ComboBoxItem Content="Сначала новые выдачи"/>
                <ComboBoxItem Content="Сначала старые выдачи"/>
                <ComboBoxItem Content="По проживающему"/>
            </ComboBox>
        </StackPanel>

        <DataGrid x:Name="GridLogs" Grid.Row="1" Grid.Column="0" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="GridLogs_SelectionChanged" Margin="0,0,15,0" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="40"/>
                <DataGridTextColumn Header="Проживающий" Binding="{Binding Resident.FullName}" Width="*"/>
                <DataGridTextColumn Header="Инвентарь" Binding="{Binding Item.ItemName}" Width="*"/>
                <DataGridTextColumn Header="Выдал(а)" Binding="{Binding Employee.FullName}" Width="*"/>
                <DataGridTextColumn Header="Дата выдачи" Binding="{Binding IssueDate, StringFormat=dd.MM.yyyy}" Width="90"/>
                <DataGridTextColumn Header="Дата возврата" Binding="{Binding ReturnDate, StringFormat=dd.MM.yyyy}" Width="90"/>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="1" Grid.Column="1" Background="#f1f2f6" CornerRadius="5" Padding="15">
            <StackPanel>
                <TextBlock Text="ОФОРМЛЕНИЕ ВЫДАЧИ" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <TextBlock Text="Проживающий:"/>
                <ComboBox x:Name="CmbResident" Margin="0,5,0,10" DisplayMemberPath="FullName" SelectedValuePath="ID"/>

                <TextBlock Text="Инвентарь:"/>
                <ComboBox x:Name="CmbItem" Margin="0,5,0,10" DisplayMemberPath="ItemName" SelectedValuePath="ID"/>

                <TextBlock Text="Сотрудник:"/>
                <ComboBox x:Name="CmbEmployee" Margin="0,5,0,10" DisplayMemberPath="FullName" SelectedValuePath="ID"/>

                <TextBlock Text="Дата выдачи:"/>
                <DatePicker x:Name="DpIssueDate" Margin="0,5,0,10"/>

                <TextBlock Text="Дата возврата (если есть):"/>
                <DatePicker x:Name="DpReturnDate" Margin="0,5,0,10"/>

                <TextBlock Text="Количество:"/>
                <TextBox x:Name="TxtQuantity" Margin="0,5,0,20" Padding="3" Text="1"/>

                <Button x:Name="BtnAdd" Content="Добавить запись" Height="35" Margin="0,0,0,10" Background="#2ecc71" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnAdd_Click"/>
                <Button x:Name="BtnUpdate" Content="Сохранить изменения" Height="35" Margin="0,0,0,10" Background="#3498db" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnUpdate_Click"/>
                <Button x:Name="BtnDelete" Content="Удалить выбранное" Height="35" Margin="0,0,0,20" Background="#e74c3c" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnDelete_Click"/>

                <Separator Margin="0,0,0,20"/>

                <Button x:Name="BtnClear" Content="Очистить поля" Height="30" Background="#95a5a6" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnClear_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
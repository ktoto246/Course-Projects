<Page x:Class="WpfApp1.Pages.TransactionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Финансы" Background="#F5F2EB" Loaded="Page_Loaded">

    <Page.Resources>
        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,2"/>
            <Setter Property="Foreground" Value="#3E2723"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="BorderBrush" Value="#8B4513"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="Background" Value="#A0522D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Page.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <DataGrid x:Name="TransactionsGrid" Grid.Column="0" AutoGenerateColumns="False" 
                  IsReadOnly="True" Margin="0,0,15,0" 
                  SelectionChanged="TransactionsGrid_SelectionChanged"
                  Background="White" RowBackground="#FFFFFF" AlternatingRowBackground="#FDF9F1"
                  BorderBrush="#D7CCC8" BorderThickness="1" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding TransactionID}" Width="Auto"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding TransactionDate, StringFormat=dd.MM.yyyy}" Width="Auto"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="Auto"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat=N2}" Width="Auto"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="*"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding Employee.LastName}" Width="*"/>
                <DataGridTextColumn Header="Участок" Binding="{Binding Plot.Name}" Width="*"/>
                <DataGridTextColumn Header="Контрагент" Binding="{Binding Counterparty.Name}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Column="1" Background="White" Padding="15" CornerRadius="8" BorderBrush="#D7CCC8" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Управление транзакцией" FontSize="18" FontWeight="Bold" Foreground="#3E2723" Margin="0,0,0,10" HorizontalAlignment="Center"/>

                    <TextBlock Text="Дата*" Style="{StaticResource InputLabel}"/>
                    <DatePicker x:Name="dpDate" Margin="0,0,0,5" BorderBrush="#8B4513"/>

                    <TextBlock Text="Тип*" Style="{StaticResource InputLabel}"/>
                    <ComboBox x:Name="cmbType" Margin="0,0,0,5" BorderBrush="#8B4513" Padding="5">
                        <ComboBoxItem Content="доход"/>
                        <ComboBoxItem Content="расход"/>
                    </ComboBox>

                    <TextBlock Text="Сумма*" Style="{StaticResource InputLabel}"/>
                    <TextBox x:Name="txtAmount" Style="{StaticResource InputBox}"/>

                    <TextBlock Text="Категория*" Style="{StaticResource InputLabel}"/>
                    <TextBox x:Name="txtCategory" Style="{StaticResource InputBox}"/>

                    <TextBlock Text="Описание" Style="{StaticResource InputLabel}"/>
                    <TextBox x:Name="txtDescription" Style="{StaticResource InputBox}" TextWrapping="Wrap" Height="50" AcceptsReturn="True"/>

                    <TextBlock Text="Сотрудник*" Style="{StaticResource InputLabel}"/>
                    <ComboBox x:Name="cmbEmployee" Margin="0,0,0,5" BorderBrush="#8B4513" Padding="5"
                              DisplayMemberPath="LastName" SelectedValuePath="EmployeeID"/>

                    <TextBlock Text="Участок (опционально)" Style="{StaticResource InputLabel}"/>
                    <ComboBox x:Name="cmbPlot" Margin="0,0,0,5" BorderBrush="#8B4513" Padding="5"
                              DisplayMemberPath="Name" SelectedValuePath="PlotID"/>

                    <TextBlock Text="Контрагент (опционально)" Style="{StaticResource InputLabel}"/>
                    <ComboBox x:Name="cmbCounterparty" Margin="0,0,0,5" BorderBrush="#8B4513" Padding="5"
                              DisplayMemberPath="Name" SelectedValuePath="CounterpartyID"/>

                    <Button Content="Очистить списки (Участок/Контрагент)" Background="#BDC3C7" Foreground="Black" Padding="5" Margin="0,5,0,10" BorderThickness="0" Cursor="Hand" Click="BtnClearCombos_Click"/>

                    <Button Content="Добавить" Style="{StaticResource ActionButton}" Background="#27AE60" Click="BtnAdd_Click"/>
                    <Button Content="Сохранить" Style="{StaticResource ActionButton}" Background="#2980B9" Click="BtnUpdate_Click"/>
                    <Button Content="Удалить" Style="{StaticResource ActionButton}" Background="#C0392B" Click="BtnDelete_Click"/>
                    <Button Content="Очистить форму" Style="{StaticResource ActionButton}" Background="#7F8C8D" Click="BtnClear_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
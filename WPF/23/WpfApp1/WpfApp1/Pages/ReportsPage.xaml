<Page x:Class="WpfApp1.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="Отчеты" Background="#F5F2EB" Loaded="Page_Loaded">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Финансовые показатели" FontSize="22" FontWeight="Bold" Foreground="#3E2723" Margin="0,0,0,15"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" Margin="0,0,10,0" CornerRadius="8" Padding="15" BorderBrush="#D7CCC8" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Соотношение доходов и расходов" FontWeight="Bold" FontSize="16" Foreground="#3E2723" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <lvc:PieChart x:Name="PieChartInOut" Grid.Row="1" LegendPosition="Right"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" Margin="10,0,0,0" CornerRadius="8" Padding="15" BorderBrush="#D7CCC8" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Структура расходов по категориям" FontWeight="Bold" FontSize="16" Foreground="#3E2723" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <lvc:CartesianChart x:Name="BarChartCategory" Grid.Row="1"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
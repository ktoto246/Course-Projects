<Page x:Class="WpfApp1.Pages.PlotsCropsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Участки и Культуры" Background="#F5F2EB" Loaded="Page_Loaded">

    <Page.Resources>
        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,2"/>
            <Setter Property="Foreground" Value="#3E2723"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="BorderBrush" Value="#8B4513"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="Background" Value="#A0522D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Page.Resources>

    <Grid Margin="15">
        <TabControl Background="Transparent" BorderThickness="0">

            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Культуры" FontSize="16" FontWeight="Bold" Foreground="#3E2723"/>
                </TabItem.Header>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="CropsGrid" Grid.Column="0" AutoGenerateColumns="False" 
                              IsReadOnly="True" Margin="0,0,15,0" 
                              SelectionChanged="CropsGrid_SelectionChanged"
                              Background="White" RowBackground="#FFFFFF" AlternatingRowBackground="#FDF9F1"
                              BorderBrush="#D7CCC8" BorderThickness="1" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding CropID}" Width="Auto"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="Auto"/>
                            <DataGridTextColumn Header="Срок (дни)" Binding="{Binding MaturationDays}" Width="Auto"/>
                            <DataGridTextColumn Header="Стоимость семян/га" Binding="{Binding SeedCostPerHa, StringFormat=N2}" Width="Auto"/>
                            <DataGridTextColumn Header="Урожайность (т/га)" Binding="{Binding ExpectedYieldTHa, StringFormat=N2}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Column="1" Background="White" Padding="15" CornerRadius="8" BorderBrush="#D7CCC8" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Название*" Style="{StaticResource InputLabel}"/>
                            <TextBox x:Name="txtCropName" Style="{StaticResource InputBox}"/>

                            <TextBlock Text="Тип*" Style="{StaticResource InputLabel}"/>
                            <ComboBox x:Name="cmbCropType" Margin="0,0,0,5" BorderBrush="#8B4513" Padding="5">
                                <ComboBoxItem Content="зерновые"/>
                                <ComboBoxItem Content="овощи"/>
                                <ComboBoxItem Content="фрукты"/>
                                <ComboBoxItem Content="технические"/>
                            </ComboBox>

                            <TextBlock Text="Срок созревания (дни)*" Style="{StaticResource InputLabel}"/>
                            <TextBox x:Name="txtMaturationDays" Style="{StaticResource InputBox}"/>

                            <TextBlock Text="Стоимость семян на га" Style="{StaticResource InputLabel}"/>
                            <TextBox x:Name="txtSeedCost" Style="{StaticResource InputBox}"/>

                            <TextBlock Text="Ожидаемая урожайность" Style="{StaticResource InputLabel}"/>
                            <TextBox x:Name="txtYield" Style="{StaticResource InputBox}"/>

                            <Button Content="Добавить" Style="{StaticResource ActionButton}" Background="#27AE60" Click="BtnAddCrop_Click"/>
                            <Button Content="Сохранить" Style="{StaticResource ActionButton}" Background="#2980B9" Click="BtnUpdateCrop_Click"/>
                            <Button Content="Удалить" Style="{StaticResource ActionButton}" Background="#C0392B" Click="BtnDeleteCrop_Click"/>
                            <Button Content="Очистить" Style="{StaticResource ActionButton}" Background="#7F8C8D" Click="BtnClearCrop_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Участки (Поля/Сады)" FontSize="16" FontWeight="Bold" Foreground="#3E2723"/>
                </TabItem.Header>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="PlotsGrid" Grid.Column="0" AutoGenerateColumns="False" 
                              IsReadOnly="True" Margin="0,0,15,0" 
                              SelectionChanged="PlotsGrid_SelectionChanged"
                              Background="White" RowBackground="#FFFFFF" AlternatingRowBackground="#FDF9F1"
                              BorderBrush="#D7CCC8" BorderThickness="1" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding PlotID}" Width="Auto"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Ответственный" Binding="{Binding ResponsibleEmployee.LastName}" Width="*"/>
                            <DataGridTextColumn Header="Площадь (га)" Binding="{Binding AreaHa, StringFormat=N2}" Width="Auto"/>
                            <DataGridTextColumn Header="Культура" Binding="{Binding Crop.Name}" Width="*"/>
                            <DataGridTextColumn Header="Дата посева" Binding="{Binding PlantingDate, StringFormat=dd.MM.yyyy}" Width="Auto"/>
                            <DataGridTextColumn Header="Сбор урожая" Binding="{Binding PlannedHarvestDate, StringFormat=dd.MM.yyyy}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Column="1" Background="White" Padding="15" CornerRadius="8" BorderBrush="#D7CCC8" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Название участка*" Style="{StaticResource InputLabel}"/>
                            <TextBox x:Name="txtPlotName" Style="{StaticResource InputBox}"/>

                            <TextBlock Text="Ответственный*" Style="{StaticResource InputLabel}"/>
                            <ComboBox x:Name="cmbEmployee" Margin="0,0,0,5" BorderBrush="#8B4513" Padding="5"
                                      DisplayMemberPath="LastName" SelectedValuePath="EmployeeID"/>

                            <TextBlock Text="Площадь (га)*" Style="{StaticResource InputLabel}"/>
                            <TextBox x:Name="txtArea" Style="{StaticResource InputBox}"/>

                            <TextBlock Text="Культура" Style="{StaticResource InputLabel}"/>
                            <ComboBox x:Name="cmbCrop" Margin="0,0,0,5" BorderBrush="#8B4513" Padding="5"
                                      DisplayMemberPath="Name" SelectedValuePath="CropID"/>

                            <TextBlock Text="Дата посева" Style="{StaticResource InputLabel}"/>
                            <DatePicker x:Name="dpPlantingDate" Margin="0,0,0,5" BorderBrush="#8B4513"/>

                            <TextBlock Text="План. дата сбора" Style="{StaticResource InputLabel}"/>
                            <DatePicker x:Name="dpHarvestDate" Margin="0,0,0,5" BorderBrush="#8B4513"/>

                            <Button Content="Добавить" Style="{StaticResource ActionButton}" Background="#27AE60" Click="BtnAddPlot_Click"/>
                            <Button Content="Сохранить" Style="{StaticResource ActionButton}" Background="#2980B9" Click="BtnUpdatePlot_Click"/>
                            <Button Content="Удалить" Style="{StaticResource ActionButton}" Background="#C0392B" Click="BtnDeletePlot_Click"/>
                            <Button Content="Очистить" Style="{StaticResource ActionButton}" Background="#7F8C8D" Click="BtnClearPlot_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Page>
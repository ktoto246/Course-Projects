<Page x:Class="WpfApp1.Pages.EmployeesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d" 
      Title="Сотрудники" Background="#F5F2EB" Loaded="Page_Loaded">

    <Page.Resources>
        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,2"/>
            <Setter Property="Foreground" Value="#3E2723"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="BorderBrush" Value="#8B4513"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="Background" Value="#A0522D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Page.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <DataGrid x:Name="EmployeesGrid" Grid.Column="0" AutoGenerateColumns="False" 
                  IsReadOnly="True" Margin="0,0,15,0" 
                  SelectionChanged="EmployeesGrid_SelectionChanged"
                  Background="White" RowBackground="#FFFFFF" AlternatingRowBackground="#FDF9F1"
                  BorderBrush="#D7CCC8" BorderThickness="1" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding EmployeeID}" Width="Auto"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="*"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="*"/>

                <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="*"/>
                <DataGridTextColumn Header="Дата приема" Binding="{Binding HireDate, StringFormat=dd.MM.yyyy}" Width="Auto"/>

                <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="*"/>
                <DataGridTextColumn Header="Оклад" Binding="{Binding Salary, StringFormat=N2}" Width="Auto"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Column="1" Background="White" Padding="15" CornerRadius="8" BorderBrush="#D7CCC8" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Управление сотрудником" FontSize="18" FontWeight="Bold" Foreground="#3E2723" Margin="0,0,0,10" HorizontalAlignment="Center"/>

                <TextBlock Text="Фамилия*" Style="{StaticResource InputLabel}"/>
                <TextBox x:Name="txtLastName" Style="{StaticResource InputBox}"/>

                <TextBlock Text="Имя*" Style="{StaticResource InputLabel}"/>
                <TextBox x:Name="txtFirstName" Style="{StaticResource InputBox}"/>

                <TextBlock Text="Отчество" Style="{StaticResource InputLabel}"/>
                <TextBox x:Name="txtMiddleName" Style="{StaticResource InputBox}"/>

                <TextBlock Text="Должность*" Style="{StaticResource InputLabel}"/>
                <TextBox x:Name="txtPosition" Style="{StaticResource InputBox}"/>

                <TextBlock Text="Дата приема*" Style="{StaticResource InputLabel}"/>
                <DatePicker x:Name="dpHireDate" Margin="0,0,0,5" BorderBrush="#8B4513"/>

                <TextBlock Text="Оклад*" Style="{StaticResource InputLabel}"/>
                <TextBox x:Name="txtSalary" Style="{StaticResource InputBox}"/>

                <TextBlock Text="Телефон" Style="{StaticResource InputLabel}"/>
                <TextBox x:Name="txtPhone" Style="{StaticResource InputBox}"/>

                <Button Content="Добавить" Style="{StaticResource ActionButton}" Background="#27AE60" Click="BtnAdd_Click"/>
                <Button Content="Сохранить изменения" Style="{StaticResource ActionButton}" Background="#2980B9" Click="BtnUpdate_Click"/>
                <Button Content="Удалить" Style="{StaticResource ActionButton}" Background="#C0392B" Click="BtnDelete_Click"/>
                <Button Content="Очистить форму" Style="{StaticResource ActionButton}" Background="#7F8C8D" Click="BtnClear_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="КФХ Горбов Н.И. | Управление и Учет" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen" Background="#F5F2EB">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#EAE0D5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0,8,8,0"
                                Margin="0,0,10,0">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#A0522D"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#8B4513"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#3E2723">
            <StackPanel>
                <TextBlock Text="АГРО УЧЕТ" 
                           Foreground="#F39C12" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,30,0,30"/>

                <Separator Background="#5D4037" Margin="15,0,15,20"/>

                <Button Content="👥 Сотрудники" Style="{StaticResource MenuButtonStyle}" Click="NavEmployees_Click"/>
                <Button Content="🤝 Контрагенты" Style="{StaticResource MenuButtonStyle}" Click="NavCounterparties_Click"/>
                <Button Content="🌱 Участки и Культуры" Style="{StaticResource MenuButtonStyle}" Click="NavPlotsCrops_Click"/>
                <Button Content="💰 Финансы (Доходы/Расход)" Style="{StaticResource MenuButtonStyle}" Click="NavTransactions_Click"/>

                <Separator Background="#5D4037" Margin="15,20,15,20"/>

                <Button Content="📈 Отчеты (Графики)" Style="{StaticResource MenuButtonStyle}" Click="NavReports_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="10" Margin="10">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
            </Grid>
        </Border>
    </Grid>
</Window>
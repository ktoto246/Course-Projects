<Page x:Class="WpfApp1.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="DashboardPage" Background="#121212" FontFamily="Segoe UI">

    <Page.Resources>
        <Style TargetType="Border" x:Key="StatCard">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#2D2D2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="0,0,20,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Сводка за смену" Foreground="White" FontSize="28" FontWeight="Light" Margin="0,0,0,25"/>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="120"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,10,15">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="ПРОВЕРЕНО МАШИН" Foreground="#888888" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="12" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="10,0,10,15">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="ОБЩИЙ ТОННАЖ (Т)" Foreground="#888888" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="340.5" Foreground="#F5A623" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="10,0,0,15">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="ОТКЛОНЕНИЯ ОТ НОРМЫ" Foreground="#888888" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="2" Foreground="#E74C3C" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6*"/>
                    <ColumnDefinition Width="4*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,10,0" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Динамика приемки зерна (т)" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>

                        <lvc:CartesianChart Grid.Row="1" Series="{Binding TonnageSeries}" XAxes="{Binding XAxes}" YAxes="{Binding YAxes}" Background="Transparent"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="10,0,0,0" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Доля поставщиков" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>

                        <lvc:PieChart Grid.Row="1" Series="{Binding SupplierPieSeries}" LegendPosition="Bottom" Background="Transparent" LegendTextPaint="{Binding LegendPaint}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
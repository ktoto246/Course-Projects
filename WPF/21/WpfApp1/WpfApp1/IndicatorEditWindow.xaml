<Window x:Class="WpfApp1.IndicatorEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Показатель качества" Height="420" Width="400" Background="#121212" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Наименование:" Foreground="#888888" Grid.Row="0"/>
        <TextBox x:Name="NameBox" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" BorderThickness="1" Margin="0,5,0,15" Padding="8" Grid.Row="1"/>

        <TextBlock Text="Единица измерения:" Foreground="#888888" Grid.Row="2"/>
        <TextBox x:Name="UnitBox" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" BorderThickness="1" Margin="0,5,0,15" Padding="8" Grid.Row="3"/>

        <TextBlock Text="Минимальная норма:" Foreground="#888888" Grid.Row="4"/>
        <TextBox x:Name="MinBox" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" BorderThickness="1" Margin="0,5,0,15" Padding="8" Grid.Row="5"/>

        <TextBlock Text="Максимальная норма:" Foreground="#888888" Grid.Row="6"/>
        <TextBox x:Name="MaxBox" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" BorderThickness="1" Margin="0,5,0,25" Padding="8" Grid.Row="7"/>

        <Button Content="Сохранить" Background="#F5A623" Foreground="Black" FontWeight="Bold" BorderThickness="0" Padding="10" Click="Save_Click" Grid.Row="8" Cursor="Hand" VerticalAlignment="Top"/>
    </Grid>
</Window>
<Window x:Class="WpfApp1.AnalysisEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Запись в журнал анализов" Height="520" Width="420" Background="#121212" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Машина (Партия):" Foreground="#888888" Grid.Row="0"/>
        <ComboBox x:Name="BatchComboBox" Background="#1E1E1E" Foreground="Black" BorderBrush="#333333" Margin="0,5,0,15" Padding="5" Grid.Row="1" DisplayMemberPath="VehicleNumber" SelectedValuePath="BatchId"/>

        <TextBlock Text="Лаборант:" Foreground="#888888" Grid.Row="2"/>
        <ComboBox x:Name="StaffComboBox" Background="#1E1E1E" Foreground="Black" BorderBrush="#333333" Margin="0,5,0,15" Padding="5" Grid.Row="3" DisplayMemberPath="FullName" SelectedValuePath="StaffId"/>

        <TextBlock Text="Показатель качества:" Foreground="#888888" Grid.Row="4"/>
        <ComboBox x:Name="IndicatorComboBox" Background="#1E1E1E" Foreground="Black" BorderBrush="#333333" Margin="0,5,0,15" Padding="5" Grid.Row="5" DisplayMemberPath="Name" SelectedValuePath="IndicatorId"/>

        <TextBlock Text="Результат (Значение):" Foreground="#888888" Grid.Row="6"/>
        <TextBox x:Name="ValueBox" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" BorderThickness="1" Margin="0,5,0,15" Padding="8" Grid.Row="7"/>

        <TextBlock Text="Дата и время анализа:" Foreground="#888888" Grid.Row="8"/>
        <TextBox x:Name="DateBox" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" BorderThickness="1" Margin="0,5,0,25" Padding="8" Grid.Row="9"/>

        <Button Content="Сохранить" Background="#F5A623" Foreground="Black" FontWeight="Bold" BorderThickness="0" Padding="10" Click="Save_Click" Grid.Row="10" Cursor="Hand" VerticalAlignment="Top"/>
    </Grid>
</Window>
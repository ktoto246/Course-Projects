<Window x:Class="WpfApp1.BatchEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Приемка машины" Height="400" Width="400" Background="#121212" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Поставщик:" Foreground="#888888" Grid.Row="0"/>
        <ComboBox x:Name="SupplierComboBox" Background="#1E1E1E" Foreground="Black" BorderBrush="#333333" Margin="0,5,0,15" Padding="5" Grid.Row="1" DisplayMemberPath="Name" SelectedValuePath="SupplierId"/>

        <TextBlock Text="Дата и время:" Foreground="#888888" Grid.Row="2"/>
        <TextBox x:Name="DateBox" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" BorderThickness="1" Margin="0,5,0,15" Padding="8" Grid.Row="3"/>

        <TextBlock Text="Номер машины:" Foreground="#888888" Grid.Row="4"/>
        <TextBox x:Name="VehicleBox" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" BorderThickness="1" Margin="0,5,0,15" Padding="8" Grid.Row="5"/>

        <TextBlock Text="Вес (Тонны):" Foreground="#888888" Grid.Row="6"/>
        <TextBox x:Name="WeightBox" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" BorderThickness="1" Margin="0,5,0,25" Padding="8" Grid.Row="7"/>

        <Button Content="Сохранить" Background="#F5A623" Foreground="Black" FontWeight="Bold" BorderThickness="0" Padding="10" Click="Save_Click" Grid.Row="8" Cursor="Hand" VerticalAlignment="Top"/>
    </Grid>
</Window>
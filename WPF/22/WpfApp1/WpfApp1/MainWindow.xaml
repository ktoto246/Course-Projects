<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Алфавит - Управление" Height="700" Width="1200" WindowStartupLocation="CenterScreen">
    <Grid Background="#1E1E1E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#252526" Margin="0,0,5,0">
            <TextBlock Text="ТАБЛИЦЫ" Foreground="DarkGray" FontSize="14" FontWeight="Bold" Margin="15,20,15,15"/>
            <Button Name="BtnClients" Content="Клиенты" Height="45" Margin="10,5" Background="#3E3E42" Foreground="White" BorderThickness="0" FontSize="14"/>
            <Button Name="BtnEmployees" Content="Сотрудники" Height="45" Margin="10,5" Background="#3E3E42" Foreground="White" BorderThickness="0" FontSize="14"/>
            <Button Name="BtnServices" Content="Услуги" Height="45" Margin="10,5" Background="#3E3E42" Foreground="White" BorderThickness="0" FontSize="14"/>
            <Button Name="BtnOrders" Content="Заказы" Height="45" Margin="10,5" Background="#3E3E42" Foreground="White" BorderThickness="0" FontSize="14"/>
        </StackPanel>

        <Frame Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Background="#1E1E1E"/>

        <StackPanel Grid.Column="2" Background="#252526" Margin="5,0,0,0">
            <TextBlock Text="ДЕЙСТВИЯ" Foreground="DarkGray" FontSize="14" FontWeight="Bold" Margin="15,20,15,15"/>
            <Button Name="BtnAdd" Content="Добавить запись" Height="45" Margin="10,5" Background="#2E7D32" Foreground="White" BorderThickness="0" FontSize="14"/>
            <Button Name="BtnEdit" Content="Редактировать" Height="45" Margin="10,5" Background="#1565C0" Foreground="White" BorderThickness="0" FontSize="14"/>
            <Button Name="BtnDelete" Content="Удалить" Height="45" Margin="10,5" Background="#C62828" Foreground="White" BorderThickness="0" FontSize="14"/>

            <Separator Margin="15,30,15,10" Background="#3E3E42"/>

            <TextBlock Text="АНАЛИТИКА" Foreground="DarkGray" FontSize="14" FontWeight="Bold" Margin="15,10,15,15"/>
            <Button Name="BtnStats" Content="Статистика" Height="45" Margin="10,5" Background="#EF6C00" Foreground="White" BorderThickness="0" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>
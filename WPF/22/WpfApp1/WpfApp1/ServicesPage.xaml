<Page x:Class="WpfApp1.ServicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp1"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ServicesPage">
    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,10,10,0">
            <TextBlock Text="ПОИСК:" Foreground="DarkGray" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Name="TxtSearch" Width="300" Height="30" Background="#3E3E42" Foreground="White" BorderThickness="0" Padding="5" TextChanged="TxtSearch_TextChanged"/>
        </StackPanel>

        <DataGrid Name="ServicesGrid" Grid.Row="1" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False" 
                  Background="#1E1E1E" 
                  RowBackground="#252526" 
                  Foreground="White" 
                  BorderBrush="#3E3E42" 
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#3E3E42"
                  Margin="10"
                  IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ServiceId}" Width="50"/>
                <DataGridTextColumn Header="Наименование услуги" Binding="{Binding ServiceName}" Width="*"/>
                <DataGridTextColumn Header="Базовая цена" Binding="{Binding BasePrice}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>